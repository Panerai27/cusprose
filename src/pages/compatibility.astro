---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

// Compatibility — mockup 04 — sample pair: Leo × Libra
const breakdown = [
  { label: 'Love',          score: 88 },
  { label: 'Friendship',    score: 92 },
  { label: 'Communication', score: 75 },
  { label: 'Trust',         score: 67 },
  { label: 'Intimacy',      score: 85 },
];

const signs = [
  { name: 'Aries',       glyph: '♈', slug: 'aries' },
  { name: 'Taurus',      glyph: '♉', slug: 'taurus' },
  { name: 'Gemini',      glyph: '♊', slug: 'gemini' },
  { name: 'Cancer',      glyph: '♋', slug: 'cancer' },
  { name: 'Leo',         glyph: '♌', slug: 'leo' },
  { name: 'Virgo',       glyph: '♍', slug: 'virgo' },
  { name: 'Libra',       glyph: '♎', slug: 'libra' },
  { name: 'Scorpio',     glyph: '♏', slug: 'scorpio' },
  { name: 'Sagittarius', glyph: '♐', slug: 'sagittarius' },
  { name: 'Capricorn',   glyph: '♑', slug: 'capricorn' },
  { name: 'Aquarius',    glyph: '♒', slug: 'aquarius' },
  { name: 'Pisces',      glyph: '♓', slug: 'pisces' },
];
---
<BaseLayout title="Leo & Libra · Compatibility · cusprose" path="/compatibility/" description="Fire meets air. Cosmic compatibility decoded.">
  <Nav current="Compatibility" />

  <main class="compat">
    <div class="container">
      <p class="crumb">COMPATIBILITY / LEO ♌ × LIBRA ♎</p>

      <header class="hero">
        <p class="eyebrow"><span class="star">✦</span> A COSMIC PAIRING</p>
        <h1>Leo &amp; Libra</h1>
        <p class="tagline">Fire meets air. The room gets warmer when you walk in together.</p>
      </header>

      <section class="signs" aria-label="Sign comparison">
        <div class="sign-cell">
          <div class="emblem" aria-hidden="true">
            <svg viewBox="0 0 80 80" aria-hidden="true">
              <circle cx="40" cy="40" r="38" fill="none" stroke="#d9a441" stroke-width="0.6"/>
              <!-- Leo glyph -->
              <path d="M30 32 q-6 12 4 18 q10 6 16 -4 q4 -7 -2 -10 q-6 -3 -10 2 q-3 4 0 7" fill="none" stroke="#d9a441" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="42" cy="32" r="2.5" fill="none" stroke="#d9a441" stroke-width="1.5"/>
            </svg>
          </div>
          <p class="cap-1">LEO · JUL 23 — AUG 22</p>
          <p class="cap-2">FIRE · FIXED</p>
        </div>

        <div class="amp">&amp;</div>

        <div class="sign-cell">
          <div class="emblem" aria-hidden="true">
            <svg viewBox="0 0 80 80" aria-hidden="true">
              <circle cx="40" cy="40" r="38" fill="none" stroke="#d9a441" stroke-width="0.6"/>
              <!-- Libra glyph -->
              <path d="M20 52 h40 M22 44 h36" stroke="#d9a441" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M28 44 q2 -10 12 -10 q10 0 12 10" fill="none" stroke="#d9a441" stroke-width="1.5"/>
            </svg>
          </div>
          <p class="cap-1">LIBRA · SEP 23 — OCT 22</p>
          <p class="cap-2">AIR · CARDINAL</p>
        </div>
      </section>

      <section class="breakdown" aria-label="Compatibility breakdown">
        <p class="b-head">THE BREAKDOWN</p>
        <div class="rows">
          {breakdown.map((m) => (
            <div class="row">
              <span class="m-label">{m.label}</span>
              <div class="bar"><div class="fill" style={`width:${m.score}%`}></div></div>
              <span class="m-score">{m.score}%</span>
            </div>
          ))}
        </div>
      </section>

      <section class="picker" aria-label="Daily horoscope by sign">
        <p class="b-head">READ YOUR DAILY HOROSCOPE</p>
        <ul class="picker-grid">
          {signs.map((s) => (
            <li>
              <a class="pick" href={`/horoscopes/${s.slug}/`}>
                <span class="pg" aria-hidden="true">{s.glyph}</span>
                <span class="pn">{s.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="more-pairs">
        <p class="b-head">MORE PAIRINGS COMING SOON</p>
        <p class="more-desc">We're building compatibility readings for all 144 zodiac pairings. Check back soon for yours.</p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .compat { padding-bottom: 6rem; position: relative; }
  .crumb {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 2.5rem;
  }

  .hero { text-align: center; margin-bottom: 4rem; }
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.2rem;
  }
  .eyebrow .star { color: var(--gold); margin-right: 0.4rem; }
  h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }
  .tagline {
    font-size: clamp(1rem, 1.3vw, 1.18rem);
    color: var(--ink-soft);
    max-width: 540px;
    margin: 0 auto;
  }

  .signs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 6vw, 5rem);
    margin: 4rem 0 4.5rem;
  }
  .sign-cell { text-align: center; }
  .emblem {
    width: clamp(180px, 18vw, 240px);
    aspect-ratio: 1;
    background: #f5ebdd;
    border: none;
    border-radius: 50%;
    padding: 0;
    box-shadow: 0 20px 40px rgba(22,24,58,0.1);
  }
  .emblem svg { width: 70%; height: 70%; }

  .cap-1 {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    margin-top: 1.25rem;
  }
  .cap-2 {
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 0.35rem;
  }
  .amp {
    font-size: clamp(3rem, 5vw, 4.5rem);
    color: var(--gold);
    font-family: Georgia, serif;
    align-self: center;
    margin-top: -1.5rem;
  }

  .breakdown { max-width: 760px; margin: 0 auto; }
  .b-head {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .rows { display: flex; flex-direction: column; gap: 1.1rem; }
  .row {
    display: grid;
    grid-template-columns: 130px 1fr 50px;
    align-items: center;
    gap: 1.2rem;
  }
  .m-label { font-size: 0.95rem; color: var(--ink); }
  .bar {
    height: 8px;
    background: #efe6d6;
    border-radius: 999px;
    overflow: hidden;
  }
  .fill {
    height: 100%;
    background: linear-gradient(90deg, #d9a441, #c9a856);
    border-radius: 999px;
  }
  .m-score {
    font-size: 0.85rem;
    color: var(--gold);
    font-weight: 600;
    text-align: right;
    letter-spacing: 0.05em;
  }

  .picker { max-width: 760px; margin: 4.5rem auto 0; }
  .picker .b-head { margin-bottom: 1.6rem; }
  .picker-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.7rem;
  }
  .pick {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.85rem 0.5rem;
    background: #fbf6ea;
    border: 1px solid var(--surface-border);
    border-radius: 14px;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .pick:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(22,24,58,0.08); }
  .pg { font-size: 1.5rem; color: var(--ink); }
  .pn { font-size: 0.72rem; letter-spacing: 0.04em; color: var(--ink-soft); }
  @media (max-width: 760px) { .picker-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 440px) { .picker-grid { grid-template-columns: repeat(3, 1fr); } }

  .more-pairs {
    max-width: 760px;
    margin: 3.5rem auto 0;
    text-align: center;
  }
  .more-desc {
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .row { grid-template-columns: 100px 1fr 44px; gap: 0.8rem; }
  }
</style>
