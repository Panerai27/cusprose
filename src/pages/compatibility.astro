---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { SIGNS } from '../data/signs';
import { COMPAT_PAIRS } from '../data/compatibility';
---
<BaseLayout title="Zodiac Compatibility · cusprose" path="/compatibility/" description="Cosmic compatibility decoded. Explore love, friendship, communication, trust & intimacy scores for all 144 zodiac pairings.">
  <Nav current="Compatibility" />

  <main class="compat">
    <div class="container">
      <header class="hero">
        <p class="eyebrow"><span class="star">✦</span> ZODIAC COMPATIBILITY</p>
        <h1>Find your<br/>cosmic match.</h1>
        <p class="tagline">Select two signs to explore their compatibility across love, friendship, trust, and more.</p>
      </header>

      <section class="selector" aria-label="Pick two signs">
        <p class="sel-label">CHOOSE TWO SIGNS</p>
        <div class="sel-row">
          <div class="sel-col">
            <label class="sel-heading" for="sign1">FIRST SIGN</label>
            <div class="sign-grid" id="sign1-grid">
              {SIGNS.map((s) => (
                <button type="button" class="sign-pick" data-sign={s.slug} data-grid="1">
                  <span class="sp-glyph">{s.glyph}</span>
                  <span class="sp-name">{s.name}</span>
                </button>
              ))}
            </div>
          </div>
          <div class="sel-amp">&amp;</div>
          <div class="sel-col">
            <label class="sel-heading" for="sign2">SECOND SIGN</label>
            <div class="sign-grid" id="sign2-grid">
              {SIGNS.map((s) => (
                <button type="button" class="sign-pick" data-sign={s.slug} data-grid="2">
                  <span class="sp-glyph">{s.glyph}</span>
                  <span class="sp-name">{s.name}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
        <a class="sel-go" id="sel-go" href="/compatibility/" aria-disabled="true">
          VIEW COMPATIBILITY →
        </a>
      </section>

      <section class="all-pairs">
        <p class="b-head">ALL PAIRINGS</p>
        <ul class="pairs-grid">
          {COMPAT_PAIRS.map((p) => {
            const s1 = SIGNS.find(s => s.slug === p.sign1);
            const s2 = SIGNS.find(s => s.slug === p.sign2);
            return (
              <li>
                <a class="pair-card" href={`/compatibility/${p.slug}/`}>
                  <span class="pair-glyphs">{s1?.glyph ?? ''} × {s2?.glyph ?? ''}</span>
                  <span class="pair-title">{p.title}</span>
                  <span class="pair-score">{p.overall}%</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>

      <section class="picker" aria-label="Daily horoscope by sign">
        <p class="b-head">READ YOUR DAILY HOROSCOPE</p>
        <ul class="picker-grid">
          {SIGNS.map((s) => (
            <li>
              <a class="pick" href={`/horoscopes/${s.slug}/`}>
                <span class="pg" aria-hidden="true">{s.glyph}</span>
                <span class="pn">{s.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .compat { padding-bottom: 6rem; }

  .hero { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.2rem;
  }
  .eyebrow .star { color: var(--gold); margin-right: 0.4rem; }
  h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }
  .tagline {
    font-size: clamp(1rem, 1.3vw, 1.18rem);
    color: var(--ink-soft);
    max-width: 540px;
    margin: 0 auto;
  }

  .selector {
    max-width: 860px;
    margin: 0 auto 4rem;
    text-align: center;
  }
  .sel-label {
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }
  .sel-row {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  @media (max-width: 640px) { .sel-row { flex-direction: column; align-items: center; } }
  .sel-col { flex: 1; max-width: 360px; }
  .sel-heading {
    display: block;
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
    text-align: center;
  }
  .sel-amp {
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: var(--gold);
    font-family: Georgia, serif;
    padding-top: 2rem;
  }
  @media (max-width: 640px) { .sel-amp { padding-top: 0; } }
  .sign-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }
  @media (max-width: 440px) { .sign-grid { grid-template-columns: repeat(3, 1fr); } }
  .sign-pick {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.6rem 0.3rem;
    background: #fbf6ea;
    border: 1.5px solid var(--surface-border);
    border-radius: 14px;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  }
  .sign-pick:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(22,24,58,0.06); }
  .sign-pick.selected {
    border-color: var(--gold);
    background: rgba(217,164,65,0.12);
    box-shadow: 0 0 0 2px rgba(217,164,65,0.25);
  }
  .sp-glyph { font-size: 1.2rem; color: var(--ink); }
  .sp-name { font-size: 0.62rem; letter-spacing: 0.04em; color: var(--ink-soft); }
  .sel-go {
    display: inline-block;
    margin-top: 1.5rem;
    background: var(--ink);
    color: #fff;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    transition: transform 0.2s, opacity 0.2s;
  }
  .sel-go[aria-disabled="true"] { opacity: 0.4; pointer-events: none; }
  .sel-go:hover { transform: translateY(-1px); }

  .all-pairs { max-width: 860px; margin: 0 auto 4rem; }
  .b-head {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .pairs-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.7rem;
  }
  .pair-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1rem 0.6rem;
    background: var(--surface);
    backdrop-filter: blur(8px);
    border: 1px solid var(--surface-border);
    border-radius: 14px;
    text-align: center;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .pair-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(22,24,58,0.08); }
  .pair-glyphs { font-size: 1.1rem; color: var(--ink); }
  .pair-title { font-size: 0.78rem; font-weight: 500; color: var(--ink); }
  .pair-score { font-size: 0.7rem; color: var(--gold); font-weight: 600; }

  .picker { max-width: 760px; margin: 4.5rem auto 0; }
  .picker .b-head { margin-bottom: 1.6rem; }
  .picker-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.7rem;
  }
  .pick {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.85rem 0.5rem;
    background: #fbf6ea;
    border: 1px solid var(--surface-border);
    border-radius: 14px;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .pick:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(22,24,58,0.08); }
  .pg { font-size: 1.5rem; color: var(--ink); }
  .pn { font-size: 0.72rem; letter-spacing: 0.04em; color: var(--ink-soft); }
  @media (max-width: 760px) { .picker-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 440px) { .picker-grid { grid-template-columns: repeat(3, 1fr); } }
</style>

<script>
  const grids = { '1': document.getElementById('sign1-grid'), '2': document.getElementById('sign2-grid') };
  const goBtn = document.getElementById('sel-go') as HTMLAnchorElement | null;
  const selected: Record<string, string | null> = { '1': null, '2': null };
  const slugs = JSON.parse(JSON.stringify({COMPAT_PAIRS_SLUGS: []}));

  document.querySelectorAll('.sign-pick').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const grid = el.dataset.grid!;
      const sign = el.dataset.sign!;
      const container = grids[grid];
      if (!container) return;
      container.querySelectorAll('.sign-pick').forEach(b => b.classList.remove('selected'));
      el.classList.add('selected');
      selected[grid] = sign;
      updateGoBtn();
    });
  });

  function updateGoBtn() {
    if (!goBtn) return;
    const s1 = selected['1'];
    const s2 = selected['2'];
    if (s1 && s2) {
      const sorted = [s1, s2].sort();
      const slug = sorted[0] + '-' + sorted[1];
      goBtn.href = '/compatibility/' + slug + '/';
      goBtn.removeAttribute('aria-disabled');
    } else {
      goBtn.href = '/compatibility/';
      goBtn.setAttribute('aria-disabled', 'true');
    }
  }
</script>
