---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { HEXAGRAMS } from '../../data/ichingHexagrams';

const TRIGRAM_LINES: Record<string, string[]> = {
  'Heaven':  ['yang','yang','yang'],
  'Earth':   ['yin','yin','yin'],
  'Water':   ['yin','yang','yin'],
  'Fire':    ['yang','yin','yang'],
  'Thunder': ['yang','yin','yin'],
  'Mountain':['yin','yin','yang'],
  'Wind':    ['yang','yang','yin'],
  'Lake':    ['yin','yang','yang'],
};

interface HexSummary {
  slug: string; number: number; name: string;
  chinese: string; english: string;
  judgment: string; interpretation: string;
  lines: string[];
}

const hexLookup: Record<string, HexSummary> = {};
for (const h of HEXAGRAMS) {
  hexLookup[`${h.trigrams.upper}:${h.trigrams.lower}`] = {
    slug: h.slug, number: h.number, name: h.name,
    chinese: h.chinese, english: h.english,
    judgment: h.judgment,
    interpretation: h.interpretation.split('\n\n')[0],
    lines: h.lines,
  };
}
---
<BaseLayout title="Cast the I Ching · cusprose" path="/iching/" description="Cast a hexagram using the ancient three-coin method. Six tosses, one answer. 64 hexagrams of the Book of Changes.">
  <Nav />

  <main class="iching"
        data-hex-lookup={JSON.stringify(hexLookup)}
        data-trigram-lines={JSON.stringify(TRIGRAM_LINES)}>
    <div class="container">

      <!-- STAGE 1: ASK -->
      <section class="stage stage-ask is-active" data-stage="ask">
        <p class="eyebrow"><span class="star">✦</span> I CHING CASTING</p>
        <header class="hero">
          <h1>What do you<br/>seek to know?</h1>
          <p class="lede">Hold your question gently. The coins will answer with one of 64 hexagrams from the Book of Changes.</p>
        </header>

        <form class="ask-form" autocomplete="off">
          <div class="ask-wrap">
            <input type="text" class="ask-input" name="q" maxlength="120"
                   placeholder="Type your question…" aria-label="Your question" />
            <button type="submit" class="ask-send" aria-label="Cast hexagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
          </div>
          <div class="chips" role="group" aria-label="Quick topics">
            <button type="button" class="chip" data-chip="Direction">Direction</button>
            <button type="button" class="chip is-on" data-chip="Guidance">Guidance</button>
            <button type="button" class="chip" data-chip="Change">Change</button>
          </div>
        </form>
      </section>

      <!-- STAGE 2: CAST -->
      <section class="stage stage-cast" data-stage="cast" hidden>
        <p class="eyebrow"><span class="star">✦</span> CASTING</p>
        <header class="hero">
          <h1>Tossing<br/>the coins…</h1>
          <p class="lede">Three coins, six times. Each toss builds one line of your hexagram, from bottom to top.</p>
        </header>

        <div class="cast-wrap">
          <div class="cast-coins" aria-hidden="true">
            <span class="coin">☰</span>
            <span class="coin">☰</span>
            <span class="coin">☰</span>
          </div>

          <div class="cast-figure">
            <div class="cast-line" data-line="6"><span class="cast-num">6</span><span class="cast-bar"></span></div>
            <div class="cast-line" data-line="5"><span class="cast-num">5</span><span class="cast-bar"></span></div>
            <div class="cast-line" data-line="4"><span class="cast-num">4</span><span class="cast-bar"></span></div>
            <div class="cast-line" data-line="3"><span class="cast-num">3</span><span class="cast-bar"></span></div>
            <div class="cast-line" data-line="2"><span class="cast-num">2</span><span class="cast-bar"></span></div>
            <div class="cast-line" data-line="1"><span class="cast-num">1</span><span class="cast-bar"></span></div>
          </div>
        </div>

        <p class="cast-status">Line <span class="cast-current">1</span> of 6</p>
        <button type="button" class="cast-toss-btn">TOSS COINS ☯</button>
      </section>

      <!-- STAGE 3: REVEAL -->
      <section class="stage stage-reveal" data-stage="reveal" hidden>
        <div class="reveal-grid">
          <section class="reveal-hero">
            <p class="eyebrow"><span class="star">✦</span> YOUR HEXAGRAM</p>
            <p class="reveal-number"></p>
            <h1 class="reveal-title"></h1>
            <p class="reveal-english"></p>
          </section>

          <aside class="reveal-figure">
            <p class="fig-head">THE FIGURE</p>
            <div class="reveal-lines"></div>
          </aside>

          <section class="reveal-reading">
            <div class="panel">
              <p class="p-head">JUDGMENT</p>
              <blockquote class="reveal-judgment"></blockquote>
            </div>
            <div class="panel">
              <p class="p-head">INTERPRETATION</p>
              <p class="reveal-interp"></p>
            </div>
          </section>
        </div>

        <div class="reveal-actions">
          <a class="btn-primary reveal-link" href="/iching/">READ FULL HEXAGRAM →</a>
          <button type="button" class="btn-again">CAST AGAIN</button>
        </div>
      </section>

      <!-- ALL HEXAGRAMS (always visible) -->
      <section class="all-hex">
        <p class="all-head">ALL 64 HEXAGRAMS</p>
        <ul class="hex-grid">
          {HEXAGRAMS.map((h) => (
            <li>
              <a class="hex-card" href={`/iching/${h.slug}/`}>
                <span class="hex-num">{h.number}</span>
                <span class="hex-cn" aria-hidden="true">{h.chinese}</span>
                <span class="hex-name">{h.name}</span>
                <span class="hex-eng">{h.english}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .iching { padding-bottom: 6rem; }

  /* --- Shared --- */
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .eyebrow .star { color: var(--gold); margin-right: 0.4rem; }
  .hero { text-align: center; margin-bottom: 2rem; }
  h1 {
    font-size: clamp(3rem, 6.5vw, 5.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 1.4rem;
  }
  .lede {
    font-size: 1.05rem;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 520px;
    margin: 0 auto;
  }

  /* --- Stages --- */
  .stage { display: none; }
  .stage.is-active { display: block; animation: rise 0.5s ease; }
  @keyframes rise {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* --- ASK --- */
  .ask-form { max-width: 440px; margin: 2rem auto 0; }
  .ask-wrap {
    display: flex;
    border: 1.5px solid var(--surface-border);
    border-radius: 999px;
    background: var(--surface);
    backdrop-filter: blur(8px);
    overflow: hidden;
    padding: 0.35rem 0.35rem 0.35rem 1.2rem;
  }
  .ask-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--ink);
    outline: none;
  }
  .ask-input::placeholder { color: var(--ink-soft); opacity: 0.6; }
  .ask-send {
    width: 40px; height: 40px;
    border-radius: 50%;
    border: none;
    background: var(--ink);
    color: #fff;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: transform 0.15s;
  }
  .ask-send:hover { transform: scale(1.08); }
  .chips {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .chip {
    font-family: inherit;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--surface-border);
    background: transparent;
    color: var(--ink-soft);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .chip.is-on {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }

  /* --- CAST --- */
  .cast-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    margin: 2rem auto;
    max-width: 360px;
  }
  .cast-coins {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
  }
  .coin {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(145deg, #d9a441, #c4902e);
    color: #fff;
    font-size: 1.4rem;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 16px rgba(217,164,65,0.3);
    transition: transform 0.3s;
  }
  .coin.flipping {
    animation: coinFlip 0.6s ease;
  }
  @keyframes coinFlip {
    0%   { transform: rotateY(0deg) scale(1); }
    50%  { transform: rotateY(180deg) scale(1.15); }
    100% { transform: rotateY(360deg) scale(1); }
  }
  .coin.heads { background: linear-gradient(145deg, #d9a441, #c4902e); }
  .coin.tails { background: linear-gradient(145deg, #6e6e8f, #4a4a68); }

  .cast-figure {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: 100%;
    background: var(--surface);
    backdrop-filter: blur(12px);
    border: 1px solid var(--surface-border);
    border-radius: 20px;
    padding: 1.5rem 1.4rem;
  }
  .cast-line {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    height: 28px;
    opacity: 0.2;
    transition: opacity 0.4s;
  }
  .cast-line.done { opacity: 1; }
  .cast-line.active { opacity: 0.7; }
  .cast-num {
    font-size: 0.7rem;
    color: var(--ink-soft);
    width: 14px;
    text-align: right;
  }
  .cast-bar {
    flex: 1;
    display: flex;
    gap: 8px;
    justify-content: center;
    height: 8px;
  }
  .cast-bar .bar {
    height: 8px;
    background: var(--ink);
    border-radius: 2px;
  }
  .cast-bar .bar.full { width: 100%; }
  .cast-bar .bar.half { width: calc(50% - 4px); }

  .cast-status {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-align: center;
  }
  .cast-toss-btn {
    display: inline-block;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    padding: 0.9rem 2.4rem;
    border-radius: 999px;
    border: none;
    background: var(--ink);
    color: #fff;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    margin-top: 0.5rem;
  }
  .cast-toss-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(22,24,58,0.15); }
  .cast-toss-btn:disabled { opacity: 0.4; pointer-events: none; }

  /* --- REVEAL --- */
  .reveal-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
    margin-bottom: 3rem;
  }
  @media (max-width: 980px) {
    .reveal-grid { grid-template-columns: 1fr; }
  }
  .reveal-hero { text-align: left; }
  .reveal-hero .eyebrow { text-align: left; }
  .reveal-hero h1 { font-size: clamp(2.5rem, 5vw, 4.5rem); }
  .reveal-number {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .reveal-english {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin-top: 0.8rem;
  }

  .reveal-figure {
    background: var(--surface);
    backdrop-filter: blur(12px);
    border: 1px solid var(--surface-border);
    border-radius: 20px;
    padding: 1.8rem 1.6rem;
    box-shadow: 0 14px 40px rgba(22,24,58,0.08);
    text-align: center;
  }
  .fig-head {
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }
  .reveal-lines {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .reveal-line-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.3rem 0.4rem;
  }
  .reveal-line-row .line-num {
    font-size: 0.7rem;
    color: var(--ink-soft);
    width: 14px;
    text-align: right;
  }
  .reveal-line-row .line-glyph {
    flex: 1;
    display: flex;
    gap: 8px;
    justify-content: center;
  }
  .reveal-line-row .bar {
    height: 8px;
    background: var(--ink);
    border-radius: 2px;
  }
  .reveal-line-row .bar.full { width: 100%; }
  .reveal-line-row .bar.half { width: calc(50% - 4px); }

  .reveal-reading { display: flex; flex-direction: column; gap: 1.6rem; }
  .panel { padding-left: 0; }
  .p-head {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.7rem;
  }
  .p-body { font-size: 1rem; line-height: 1.55; color: var(--ink); }
  blockquote {
    font-size: 1.4rem;
    line-height: 1.3;
    font-style: italic;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .reveal-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .btn-primary {
    display: inline-block;
    background: var(--ink);
    color: #fff;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    transition: transform 0.2s;
    text-decoration: none;
  }
  .btn-primary:hover { transform: translateY(-1px); }
  .btn-again {
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    padding: 0.9rem 2rem;
    border-radius: 999px;
    border: 1.5px solid var(--ink);
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition: transform 0.2s;
  }
  .btn-again:hover { transform: translateY(-1px); }

  /* --- ALL HEXAGRAMS --- */
  .all-hex { margin-top: 5rem; }
  .all-head {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .hex-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.7rem;
  }
  .hex-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.9rem 0.5rem;
    background: var(--surface);
    backdrop-filter: blur(8px);
    border: 1px solid var(--surface-border);
    border-radius: 14px;
    text-align: center;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .hex-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(22,24,58,0.08); }
  .hex-num {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--ink-soft);
  }
  .hex-cn {
    font-size: 1.4rem;
    color: var(--gold);
    line-height: 1.2;
  }
  .hex-name {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink);
  }
  .hex-eng {
    font-size: 0.62rem;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }
</style>

<script>
  const root = document.querySelector('.iching') as HTMLElement;
  const hexLookup = JSON.parse(root.dataset.hexLookup!);
  const trigramLines = JSON.parse(root.dataset.trigramLines!);
  const stages = document.querySelectorAll<HTMLElement>('.stage');
  const castLines: string[] = [];
  let currentLine = 1;

  function show(name: string) {
    stages.forEach(s => {
      s.classList.remove('is-active');
      s.hidden = true;
    });
    const el = document.querySelector(`[data-stage="${name}"]`) as HTMLElement;
    el.hidden = false;
    void el.offsetWidth;
    el.classList.add('is-active');
  }

  // --- ASK ---
  const askForm = document.querySelector('.ask-form') as HTMLFormElement;
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');

  chips.forEach(c => c.addEventListener('click', () => {
    chips.forEach(x => x.classList.remove('is-on'));
    c.classList.add('is-on');
    const input = askForm.querySelector('.ask-input') as HTMLInputElement;
    input.value = c.dataset.chip || '';
  }));

  askForm.addEventListener('submit', (e) => {
    e.preventDefault();
    castLines.length = 0;
    currentLine = 1;
    resetCastUI();
    show('cast');
  });

  // --- CAST ---
  const tossBtn = document.querySelector('.cast-toss-btn') as HTMLButtonElement;
  const castCurrentEl = document.querySelector('.cast-current') as HTMLElement;
  const coins = document.querySelectorAll<HTMLElement>('.coin');
  const castLineEls = document.querySelectorAll<HTMLElement>('.cast-line');

  function resetCastUI() {
    castCurrentEl.textContent = '1';
    tossBtn.disabled = false;
    tossBtn.textContent = 'TOSS COINS ☯';
    castLineEls.forEach(el => {
      el.classList.remove('done', 'active');
      const bar = el.querySelector('.cast-bar') as HTMLElement;
      bar.innerHTML = '';
    });
    const line1 = document.querySelector('[data-line="1"]') as HTMLElement;
    if (line1) line1.classList.add('active');
    coins.forEach(c => {
      c.classList.remove('heads', 'tails', 'flipping');
      c.textContent = '☰';
    });
  }

  function tossLine(): 'yang' | 'yin' {
    let sum = 0;
    const arr = new Uint8Array(3);
    crypto.getRandomValues(arr);
    const results: boolean[] = [];
    for (const v of arr) {
      const isHeads = v % 2 === 0;
      results.push(isHeads);
      sum += isHeads ? 3 : 2;
    }

    coins.forEach((c, i) => {
      c.classList.add('flipping');
      setTimeout(() => {
        c.classList.remove('flipping');
        if (results[i]) {
          c.classList.add('heads');
          c.classList.remove('tails');
          c.textContent = '☰';
        } else {
          c.classList.add('tails');
          c.classList.remove('heads');
          c.textContent = '☷';
        }
      }, 500);
    });

    return (sum === 7 || sum === 9) ? 'yang' : 'yin';
  }

  function renderCastLine(lineNum: number, type: string) {
    const el = document.querySelector(`[data-line="${lineNum}"]`) as HTMLElement;
    const bar = el.querySelector('.cast-bar') as HTMLElement;
    if (type === 'yang') {
      bar.innerHTML = '<span class="bar full"></span>';
    } else {
      bar.innerHTML = '<span class="bar half"></span><span class="bar half"></span>';
    }
    el.classList.add('done');
    el.classList.remove('active');
  }

  tossBtn.addEventListener('click', () => {
    if (currentLine > 6) return;
    tossBtn.disabled = true;

    const lineType = tossLine();

    setTimeout(() => {
      castLines.push(lineType);
      renderCastLine(currentLine, lineType);
      currentLine++;

      if (currentLine <= 6) {
        castCurrentEl.textContent = String(currentLine);
        const nextEl = document.querySelector(`[data-line="${currentLine}"]`) as HTMLElement;
        if (nextEl) nextEl.classList.add('active');
        tossBtn.disabled = false;
      } else {
        tossBtn.textContent = 'REVEALING…';
        setTimeout(() => revealHexagram(), 800);
      }
    }, 700);
  });

  // --- REVEAL ---
  function linesToTrigram(lines: string[]): string | null {
    for (const [name, pattern] of Object.entries(trigramLines)) {
      if (lines[0] === pattern[0] && lines[1] === pattern[1] && lines[2] === pattern[2]) return name;
    }
    return null;
  }

  function revealHexagram() {
    const lower = linesToTrigram(castLines.slice(0, 3));
    const upper = linesToTrigram(castLines.slice(3, 6));
    if (!lower || !upper) return;

    const key = `${upper}:${lower}`;
    const hex = hexLookup[key];
    if (!hex) return;

    const numEl = document.querySelector('.reveal-number') as HTMLElement;
    const titleEl = document.querySelector('.reveal-title') as HTMLElement;
    const engEl = document.querySelector('.reveal-english') as HTMLElement;
    const judgEl = document.querySelector('.reveal-judgment') as HTMLElement;
    const interpEl = document.querySelector('.reveal-interp') as HTMLElement;
    const linkEl = document.querySelector('.reveal-link') as HTMLAnchorElement;
    const linesEl = document.querySelector('.reveal-lines') as HTMLElement;

    numEl.textContent = `HEXAGRAM ${hex.number}`;
    titleEl.innerHTML = `${hex.name}<br/><span style="color:var(--gold);font-size:0.6em">${hex.chinese}</span>`;
    engEl.textContent = hex.english;
    judgEl.textContent = hex.judgment;
    interpEl.textContent = hex.interpretation;
    linkEl.href = `/iching/${hex.slug}/`;

    linesEl.innerHTML = '';
    for (let i = 5; i >= 0; i--) {
      const type = castLines[i];
      const row = document.createElement('div');
      row.className = 'reveal-line-row';
      row.innerHTML = `
        <span class="line-num">${i + 1}</span>
        <span class="line-glyph">
          ${type === 'yang'
            ? '<span class="bar full"></span>'
            : '<span class="bar half"></span><span class="bar half"></span>'}
        </span>`;
      linesEl.appendChild(row);
    }

    show('reveal');
  }

  // --- CAST AGAIN ---
  const againBtn = document.querySelector('.btn-again') as HTMLButtonElement;
  againBtn.addEventListener('click', () => {
    castLines.length = 0;
    currentLine = 1;
    show('ask');
  });
</script>
