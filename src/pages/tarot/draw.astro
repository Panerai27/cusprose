---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

const deck = [
  { roman: 'XVII',  name: 'The Star',   keywords: 'HOPE · RENEWAL',      bg: 'var(--card-lavender)', rotate: -14 },
  { roman: 'XVIII', name: 'The Moon',   keywords: 'INTUITION · DREAMS',  bg: 'var(--card-peach)',    rotate: -7  },
  { roman: 'XIX',   name: 'The Sun',    keywords: 'JOY · VITALITY',      bg: 'var(--card-sage)',     rotate: 0   },
  { roman: 'X',     name: 'Wheel',      keywords: 'CHANGE · FORTUNE',    bg: 'var(--card-lavender)', rotate: 7   },
  { roman: 'I',     name: 'Magician',   keywords: 'WILL · MASTERY',      bg: 'var(--card-peach)',    rotate: 14  },
];
---
<BaseLayout title="Daily Tarot Draw · cusprose" path="/tarot/draw/" description="Pull a single card from a shuffled 78-card deck. A daily reflection, designed for who you are now.">
  <Nav current="Tarot" />

  <main class="draw">
    <div class="container">
      <p class="crumb">TAROT / DRAW</p>

      <header class="head">
        <p class="eyebrow"><span class="star">✦</span> ONE CARD DAILY</p>
        <h1>What does today<br/>want you to see?</h1>
        <p class="lede">Take a breath. Hold your question loosely. Choose the card that finds your hand.</p>
      </header>

      <div class="fan" aria-label="Five face-down cards, fanned">
        {deck.map((c, i) => (
          <button
            class="card"
            style={`--rot:${c.rotate}deg; --bg:${c.bg}; --i:${i};`}
            aria-label={`Card ${i + 1}`}
          >
            <span class="back">
              <span class="back-mark">✦</span>
            </span>
          </button>
        ))}
      </div>

      <div class="meta">
        <div class="meta-item">
          <p class="m-head">DECK</p>
          <p class="m-body">Rider–Waite · 78 cards</p>
        </div>
        <div class="meta-item">
          <p class="m-head">SHUFFLE</p>
          <p class="m-body">crypto.getRandomValues</p>
        </div>
        <div class="meta-item">
          <p class="m-head">RESET</p>
          <p class="m-body">Every 24h, your time</p>
        </div>
      </div>

      <p class="note">A reading is a mirror, not a script.</p>
    </div>
  </main>
</BaseLayout>

<style>
  .draw { padding-bottom: 6rem; }
  .crumb {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 2.5rem;
  }
  .head { text-align: center; max-width: 640px; margin: 0 auto 4rem; }
  .eyebrow { margin-bottom: 1.25rem; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); }
  .eyebrow .star { color: var(--gold); margin-right: 0.4rem; }
  h1 {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 1.4rem;
  }
  .lede { color: var(--ink-soft); font-size: 1.05rem; line-height: 1.55; }

  .fan {
    position: relative;
    height: 360px;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    margin-bottom: 4rem;
  }
  .card {
    appearance: none;
    border: none;
    background: transparent;
    width: 170px;
    height: 260px;
    margin: 0 -34px;
    transform: rotate(var(--rot)) translateY(0);
    transition: transform 0.35s ease;
    cursor: pointer;
    padding: 0;
  }
  .card:hover { transform: rotate(var(--rot)) translateY(-22px); }
  .card .back {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 18px;
    background:
      radial-gradient(circle at 50% 50%, rgba(255,255,255,0.18) 0%, transparent 60%),
      linear-gradient(160deg, var(--bg) 0%, rgba(22,24,58,0.08) 100%);
    border: 1.5px solid rgba(255,255,255,0.7);
    box-shadow: 0 18px 40px rgba(22,24,58,0.18);
    position: relative;
    overflow: hidden;
  }
  .back-mark {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 2.4rem;
    color: var(--gold);
    opacity: 0.85;
  }

  .meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 760px;
    margin: 0 auto 2rem;
    padding: 1.6rem 2rem;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 20px;
  }
  .m-head { font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 0.4rem; }
  .m-body { font-size: 0.92rem; color: var(--ink); }
  @media (max-width: 700px) {
    .meta { grid-template-columns: 1fr; text-align: center; }
  }

  .note { text-align: center; color: var(--ink-soft); font-style: italic; font-size: 0.9rem; }
</style>
