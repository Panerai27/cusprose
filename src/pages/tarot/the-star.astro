---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

// Card detail — mockup 03 — sample: The Star (XVII)
const chips = [
  { label: 'HOPE',        bg: 'var(--card-lavender)' },
  { label: 'HEALING',     bg: 'var(--card-peach)' },
  { label: 'INSPIRATION', bg: 'var(--card-sage)' },
  { label: 'WATER',       bg: '#f4efe6' },
];
---
<BaseLayout title="The Star · XVII · cusprose" path="/tarot/the-star/" description="The Star — Major Arcana XVII. After the storm, a quiet light returns.">
  <Nav current="Tarot" />

  <main class="detail">
    <div class="container">
      <p class="crumb">TAROT / MAJOR ARCANA / XVII</p>

      <div class="grid">
        <!-- Left: card visual -->
        <aside class="card-pane" aria-label="The Star card illustration">
          <div class="card-face">
            <span class="roman">XVII</span>
            <svg class="art" viewBox="0 0 120 160" aria-hidden="true">
              <!-- scattered dots -->
              <circle cx="22" cy="22" r="1" fill="#d9a441"/>
              <circle cx="40" cy="14" r="0.8" fill="#d9a441"/>
              <circle cx="60" cy="22" r="1" fill="#d9a441"/>
              <circle cx="82" cy="16" r="0.9" fill="#d9a441"/>
              <circle cx="98" cy="28" r="1" fill="#d9a441"/>
              <circle cx="18" cy="48" r="0.8" fill="#d9a441"/>
              <circle cx="100" cy="56" r="0.9" fill="#d9a441"/>
              <!-- gold circle -->
              <circle cx="60" cy="68" r="22" fill="none" stroke="#d9a441" stroke-width="0.6"/>
              <!-- gold star -->
              <path d="M60 50 l4.2 11 11.5 .8 -8.9 7.5 2.9 11.4 -9.7 -6.3 -9.7 6.3 2.9 -11.4 -8.9 -7.5 11.5 -.8z" fill="#d9a441"/>
              <!-- figure -->
              <ellipse cx="60" cy="138" rx="20" ry="3" fill="#e7dff0"/>
              <path d="M55 110 q5 -5 10 0 v18 q-5 4 -10 0 z" fill="#16183a"/>
              <circle cx="60" cy="106" r="4" fill="#16183a"/>
            </svg>
            <div class="card-title">The Star</div>
            <div class="card-keys">HOPE · RENEWAL · GUIDANCE</div>
          </div>
        </aside>

        <!-- Right: text content -->
        <section class="content">
          <p class="meta">MAJOR ARCANA · XVII</p>
          <h1>The Star</h1>
          <p class="tagline">After the storm, a quiet light returns.</p>

          <div class="chips">
            {chips.map((c) => (
              <span class="chip" style={`background:${c.bg}`}>{c.label}</span>
            ))}
          </div>

          <div class="toggle">
            <button class="t-btn active" type="button">UPRIGHT</button>
            <button class="t-btn" type="button">REVERSED</button>
          </div>

          <div class="sections">
            <div class="sec">
              <p class="sec-h">MEANING</p>
              <p class="sec-body">The Star is the breath you take after holding too much. It promises that even the longest night ends — gently, and with light enough to keep walking.</p>
            </div>
            <div class="sec">
              <p class="sec-h">IN LOVE</p>
              <p class="sec-body">Tender reconnection. Honesty without armor.</p>
            </div>
            <div class="sec">
              <p class="sec-h">IN CAREER</p>
              <p class="sec-body">A second wind. Your work begins to feel like yours again.</p>
            </div>
            <div class="sec">
              <p class="sec-h">IN SELF</p>
              <p class="sec-body">Rest is not retreat. Light yourself first.</p>
            </div>
          </div>

          <div class="actions">
            <a href="/tarot/" class="btn-primary">DRAW MY CARD →</a>
            <a href="#" class="btn-secondary">Share this card ↗</a>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .detail { padding-bottom: 6rem; }
  .crumb {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 2.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  @media (max-width: 860px) {
    .grid { grid-template-columns: 1fr; }
  }

  /* card */
  .card-pane { display: flex; justify-content: center; }
  .card-face {
    background: var(--card-lavender);
    border: 1px solid #c9a86a;
    border-radius: 22px;
    padding: 1.8rem 1.5rem;
    width: min(320px, 100%);
    aspect-ratio: 2 / 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 30px 60px rgba(22,24,58,0.18);
    text-align: center;
  }
  .roman { font-size: 0.75rem; letter-spacing: 0.2em; color: var(--ink-soft); }
  .art { width: 70%; }
  .card-title { font-size: 1.25rem; font-style: italic; color: var(--ink); }
  .card-keys { font-size: 0.62rem; letter-spacing: 0.2em; color: var(--ink-soft); }

  /* right column */
  .meta {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.6rem;
  }
  h1 {
    font-size: clamp(2.6rem, 5.5vw, 4.5rem);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin-bottom: 0.8rem;
  }
  .tagline {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
  }

  .chips { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .chip {
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    color: var(--ink);
    font-weight: 500;
  }

  .toggle { display: inline-flex; gap: 0.5rem; margin-bottom: 2.25rem; }
  .t-btn {
    font-family: inherit;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .t-btn.active { background: var(--ink); color: #fff; }

  .sections { display: flex; flex-direction: column; gap: 1.6rem; margin-bottom: 2.5rem; }
  .sec-h {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.45rem;
  }
  .sec-body { font-size: 1.05rem; line-height: 1.55; color: var(--ink); }

  .actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .btn-primary {
    background: var(--ink);
    color: #fff;
    padding: 1rem 1.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
  }
  .btn-secondary {
    color: var(--ink);
    font-size: 0.92rem;
    border-bottom: 1px solid transparent;
  }
  .btn-secondary:hover { border-bottom-color: var(--ink); }
</style>
