---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { TAROT_CARDS, SUIT_LABELS } from '../../data/tarotCards';

const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long', month: 'long', day: 'numeric'
});

// Full Major Arcana — drawn at random, client-side, with crypto randomness.
const cards = [
  { roman: '0',     name: 'The Fool',         keys: 'BEGINNINGS · FAITH · A LEAP',        up: 'A clean slate, and the nerve to step onto it. Whatever you start now carries the innocence of not yet knowing how hard it will be — and that is exactly its strength.' },
  { roman: 'I',     name: 'The Magician',     keys: 'WILL · FOCUS · MAKING',              up: 'Everything you need is already on the table. The question is no longer whether you can, but whether you will gather it and begin.' },
  { roman: 'II',    name: 'The High Priestess', keys: 'INTUITION · MYSTERY · WAITING',    up: 'Something in you already knows the answer and is waiting for you to grow quiet enough to hear it. Don\u2019t force this one. Let it surface.' },
  { roman: 'III',   name: 'The Empress',      keys: 'ABUNDANCE · NURTURE · GROWTH',       up: 'Tend what you have and it will multiply. This is a season for softness, for making things — and for letting them take their own time to ripen.' },
  { roman: 'IV',    name: 'The Emperor',      keys: 'STRUCTURE · ORDER · AUTHORITY',      up: 'Build the frame before you fill it. The freedom you\u2019re craving lives on the other side of a little discipline, not instead of it.' },
  { roman: 'V',     name: 'The Hierophant',   keys: 'TRADITION · GUIDANCE · MEANING',     up: 'There is wisdom in the well-worn path today. Seek the counsel of someone who has walked further than you — then decide what to keep.' },
  { roman: 'VI',    name: 'The Lovers',       keys: 'UNION · CHOICE · ALIGNMENT',         up: 'A choice that asks you to be honest about what you value. This isn\u2019t only about love — it\u2019s about choosing in a way you can stand behind.' },
  { roman: 'VII',   name: 'The Chariot',      keys: 'DRIVE · CONTROL · VICTORY',          up: 'Two forces pulling opposite ways, and your job is to hold the reins of both. Momentum is yours if you steer instead of letting it steer you.' },
  { roman: 'VIII',  name: 'Strength',         keys: 'COURAGE · GRACE · PATIENCE',         up: 'Real strength here is gentle. You master the situation not by force but by staying calm long enough for it to soften toward you.' },
  { roman: 'IX',    name: 'The Hermit',       keys: 'SOLITUDE · SEARCH · INSIGHT',        up: 'Step back from the noise. The answer you want from others is one you can only reach by spending a little honest time alone with yourself.' },
  { roman: 'X',     name: 'Wheel of Fortune', keys: 'CYCLES · FATE · A TURNING',          up: 'The wheel is moving whether or not you push it. Something is shifting in your favour — meet the change instead of bracing against it.' },
  { roman: 'XI',    name: 'Justice',          keys: 'TRUTH · BALANCE · CAUSE & EFFECT',   up: 'What you set in motion is coming back to meet you. Be clear, be fair, and the outcome will weigh out honestly in your favour.' },
  { roman: 'XII',   name: 'The Hanged Man',   keys: 'SURRENDER · PAUSE · NEW EYES',       up: 'The way forward is to stop struggling and hang in the pause. Seen from this angle, the thing you were fighting starts to look different.' },
  { roman: 'XIII',  name: 'Death',            keys: 'ENDINGS · RELEASE · REBIRTH',        up: 'Not a literal ending — a necessary one. Something has run its course, and letting it close is what clears the ground for what\u2019s next.' },
  { roman: 'XIV',   name: 'Temperance',       keys: 'HARMONY · PATIENCE · BLENDING',      up: 'Mix the extremes into something you can live with. The middle path isn\u2019t a compromise today — it\u2019s the wise and elegant choice.' },
  { roman: 'XV',    name: 'The Devil',        keys: 'SHADOW · DESIRE · ATTACHMENT',       up: 'Notice what you feel bound to. The chains here are looser than they look — naming the pull is the first step to loosening it.' },
  { roman: 'XVI',   name: 'The Tower',        keys: 'UPHEAVAL · TRUTH · RELEASE',         up: 'A sudden clearing-out of what was built on shaky ground. It feels like loss now; soon it will read as the truth finally arriving.' },
  { roman: 'XVII',  name: 'The Star',         keys: 'HOPE · HEALING · RENEWAL',           up: 'After the storm, a quiet light. Trust is returning to you slowly — this is the gentle, hopeful exhale you\u2019ve been needing.' },
  { roman: 'XVIII', name: 'The Moon',         keys: 'INTUITION · DREAMS · ILLUSION',      up: 'Things aren\u2019t fully clear yet, and that\u2019s alright. Don\u2019t mistake your fears for facts. Move slowly through the half-light and trust your feet.' },
  { roman: 'XIX',   name: 'The Sun',          keys: 'JOY · VITALITY · CLARITY',           up: 'Warmth, clarity, and an open road. Whatever you\u2019ve been unsure of, the answer arrives bright and simple. Let yourself enjoy it.' },
  { roman: 'XX',    name: 'Judgement',        keys: 'AWAKENING · CALLING · RECKONING',    up: 'A clear call you can no longer un-hear. Something is asking you to rise to it — and you already know, honestly, what your answer is.' },
  { roman: 'XXI',   name: 'The World',        keys: 'COMPLETION · WHOLENESS · ARRIVAL',   up: 'A chapter closes, fully and well. Take the moment to feel finished before you reach for the next thing. You earned this whole.' },
];

const positions = [
  { label: 'PAST',    hint: 'what brought you here' },
  { label: 'PRESENT', hint: 'where you stand now' },
  { label: 'FUTURE',  hint: 'where this is heading' },
];

const tints = [
  'linear-gradient(165deg, #4a3a72, #2d2350)',
  'linear-gradient(165deg, #7a4a52, #3a2238)',
  'linear-gradient(165deg, #3f5e46, #233a2c)',
];

const FAN_COUNT = 21;
---
<BaseLayout title="Pull a card for today · cusprose" path="/tarot/" description="A three-card tarot spread — past, present, future. Hold a question, shuffle the deck, and choose your own cards from the fan. 78 cards, infinite stories.">
  <!-- A-version: immersive deep-night tarot stage -->
  <div class="night" aria-hidden="true">
    <canvas class="night-stars"></canvas>
    <div class="night-aura"></div>
  </div>
  <Nav current="Tarot" />

  <!-- Reusable card-back artwork: ink ground, gold celestial eye -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <linearGradient id="inkback" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#26244e"/>
        <stop offset="55%" stop-color="#1a1838"/>
        <stop offset="100%" stop-color="#100f26"/>
      </linearGradient>
      <symbol id="cardback" viewBox="0 0 100 160">
        <rect x="2" y="2" width="96" height="156" rx="10" fill="url(#inkback)" stroke="#d9a441" stroke-width="1.1"/>
        <rect x="7.5" y="7.5" width="85" height="145" rx="7" fill="none" stroke="#d9a441" stroke-width="0.5" opacity="0.45"/>
        <g transform="translate(50 80)" stroke="#d9a441" fill="none" stroke-width="0.8" stroke-linecap="round">
          <!-- radiating rays -->
          <g opacity="0.85">
            <line x1="0" y1="-30" x2="0" y2="-21"/>
            <line x1="0" y1="30" x2="0" y2="21"/>
            <line x1="-30" y1="0" x2="-21" y2="0"/>
            <line x1="30" y1="0" x2="21" y2="0"/>
            <line x1="-21" y1="-21" x2="-15" y2="-15"/>
            <line x1="21" y1="-21" x2="15" y2="-15"/>
            <line x1="-21" y1="21" x2="-15" y2="15"/>
            <line x1="21" y1="21" x2="15" y2="15"/>
          </g>
          <!-- vesica eye -->
          <path d="M-15 0 Q0 -10 15 0 Q0 10 -15 0 Z" opacity="0.9"/>
          <circle r="4.6" opacity="0.9"/>
          <circle r="1.7" fill="#d9a441" stroke="none"/>
        </g>
        <!-- star points -->
        <g fill="#d9a441" stroke="none" opacity="0.7">
          <circle cx="22" cy="28" r="1"/>
          <circle cx="78" cy="34" r="0.8"/>
          <circle cx="30" cy="128" r="0.9"/>
          <circle cx="72" cy="124" r="1"/>
          <circle cx="50" cy="20" r="0.7"/>
          <circle cx="50" cy="140" r="0.7"/>
        </g>
      </symbol>
    </defs>
  </svg>

  <main class="tarot" data-cards={JSON.stringify(cards)}>
    <div class="container">

      <!-- STATE 1 · ASK -->
      <section class="stage stage-ask is-active" data-stage="ask">
        <p class="datestamp"><span class="star">✦</span> THREE-CARD SPREAD · {today.toUpperCase()}</p>
        <header class="hero">
          <h1>What would you<br/>like to know?</h1>
          <p class="lede">Hold a question gently in mind. The deck will meet you where you are.</p>
        </header>

        <form class="ask-form" autocomplete="off">
          <div class="ask-wrap">
            <input type="text" class="ask-input" name="q" maxlength="120"
                   placeholder="Type your question…" aria-label="Your question" />
            <button type="submit" class="ask-send" aria-label="Draw cards">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
          </div>
          <div class="chips" role="group" aria-label="Quick topics">
            <button type="button" class="chip" data-chip="Love">Love</button>
            <button type="button" class="chip is-on" data-chip="Today">Today</button>
            <button type="button" class="chip" data-chip="Career">Career</button>
          </div>
        </form>
      </section>

      <!-- STATE 2 · SHUFFLE -->
      <section class="stage stage-shuffle" data-stage="shuffle" hidden>
        <p class="datestamp"><span class="star">✦</span> CHANNELING</p>
        <header class="hero">
          <h1>Shuffling<br/>the deck…</h1>
          <p class="lede">Breathe in. Breathe out. When you feel ready, the cards will settle.</p>
        </header>
        <div class="fan" aria-hidden="true">
          {Array.from({ length: 9 }).map((_, i) => {
            const r = -32 + i * 8;
            return (
              <span class="fan-card" style={`--r:${r}deg; animation-delay:${(-i * 0.1).toFixed(1)}s`}>
                <svg viewBox="0 0 100 160"><use href="#cardback"/></svg>
              </span>
            );
          })}
        </div>
      </section>

      <!-- STATE 3 · PICK (immersive, dark) -->
      <section class="stage stage-pick" data-stage="pick" hidden>
        <div class="pick-sky" aria-hidden="true"></div>
        <div class="pick-dust" aria-hidden="true">
          {Array.from({ length: 14 }).map((_, i) => (
            <i style={`left:${(i * 7 + 4) % 100}%; --dx:${(i % 2 ? 1 : -1) * (8 + (i % 4) * 6)}px; animation-duration:${9 + (i % 5) * 2.4}s; animation-delay:${(i * 0.9) % 8}s; width:${2 + (i % 3)}px; height:${2 + (i % 3)}px;`}></i>
          ))}
        </div>
        <p class="datestamp"><span class="star">✦</span> CHOOSE YOUR CARDS</p>
        <header class="hero">
          <h1>Pick three.</h1>
          <p class="lede">Don’t overthink it. Let your hand fall to the cards that pull at you.</p>
        </header>
        <p class="pick-counter"><span class="pick-left">3</span> cards left</p>
        <div class="pick-fan" role="group" aria-label="Face-down tarot cards — choose three">
          {Array.from({ length: FAN_COUNT }).map((_, i) => (
            <button type="button" class="pick-card" data-pick={i}
                    style={`--i:${i}; --n:${FAN_COUNT}`}
                    aria-label={`Face-down card ${i + 1}`}>
              <svg viewBox="0 0 100 160"><use href="#cardback"/></svg>
              <span class="pick-badge" aria-hidden="true"></span>
            </button>
          ))}
        </div>
      </section>

      <!-- STATE 4 · REVEAL -->
      <section class="stage stage-reveal" data-stage="reveal" hidden>
        <p class="datestamp"><span class="star">✦</span> YOUR SPREAD</p>
        <header class="hero">
          <h1>The cards<br/>have spoken.</h1>
          <p class="lede reveal-q">Past, present, future — a small constellation around your question.</p>
        </header>

        <div class="reveal-row">
          {positions.map((p, i) => (
            <article class="slot" data-slot={i} style={`--tint:${tints[i]}`}>
              <button type="button" class="rcard" aria-label={`Reveal the ${p.label.toLowerCase()} card`}>
                <span class="rflip">
                  <span class="rface rback">
                    <svg viewBox="0 0 100 160"><use href="#cardback"/></svg>
                  </span>
                  <span class="rface rfront">
                    <span class="rf-roman"></span>
                    <span class="rf-glyph">✦</span>
                    <span class="rf-name"></span>
                    <span class="rf-keys"></span>
                  </span>
                </span>
              </button>
              <p class="r-pos">{p.label}</p>
              <p class="r-meaning"></p>
            </article>
          ))}
        </div>

        <p class="tap-all-hint">TAP EACH CARD TO TURN IT OVER</p>

        <section class="spread-reading" aria-live="polite" hidden>
          <p class="reading-kicker">YOUR READING</p>
          <h2 class="reading-title">What the spread is saying</h2>
          <p class="reading-summary"></p>
          <div class="reading-grid">
            <article>
              <span>Past</span>
              <p class="reading-past"></p>
            </article>
            <article>
              <span>Present</span>
              <p class="reading-present"></p>
            </article>
            <article>
              <span>Future</span>
              <p class="reading-future"></p>
            </article>
          </div>
          <p class="reading-advice"></p>
        </section>

        <div class="reveal-actions">
          <button type="button" class="btn-ghost btn-read-spread">Read this spread</button>
          <button type="button" class="btn-again">Draw again</button>
        </div>
      </section>

    </div>

    <section class="tarot-about" aria-labelledby="about-title">
      <p class="about-kicker"><span class="star">✦</span> ABOUT THIS READING</p>
      <h2 id="about-title">Free 3-Card Tarot Reading, Online</h2>
      <div class="about-grid">
        <p>Tarot is a quiet way of checking in with yourself — a mirror for where you are right now and the next small step that might move you forward. Pulling a few cards every couple of months makes room for reflection and helps you notice what you already know underneath the noise.</p>
        <p>Our free reading is built to surface the thoughts and feelings sitting just below the surface. It won't predict your future or hand you certainties — instead it draws on your own intuition, helping you read your strengths and use them on the path you're already walking.</p>
        <p>The three-card spread — <em>past, present, future</em> — is the most loved place to begin. It's quick, focused, and works beautifully for a single question on your mind: a relationship, a decision, a feeling you can't name yet.</p>
        <p>Before you begin, take a breath. Centre yourself, hold your question gently, and let your hand fall to the cards that pull at you. Don't pick to get the answer you want — sit with the cards you're given. That's where the insight lives.</p>
      </div>

      <div class="about-how">
        <h3>How a cusprose reading works</h3>
        <ol class="how-steps">
          <li><span class="how-n">1</span><span><strong>Ask.</strong> Name the question that's actually on your mind — the more honest, the clearer the mirror.</span></li>
          <li><span class="how-n">2</span><span><strong>Shuffle.</strong> Take a breath while the deck settles. There's no rush; the moment you feel ready is the right one.</span></li>
          <li><span class="how-n">3</span><span><strong>Choose.</strong> Pull three cards from the fan yourself — past, present, future. You pick them; we don't pick for you.</span></li>
          <li><span class="how-n">4</span><span><strong>Read.</strong> Each card is interpreted in its position and in relation to the others, so the spread reads as one story, not three fragments.</span></li>
        </ol>
      </div>

      <div class="about-faq">
        <h3>Questions people ask</h3>
        <details>
          <summary>Is this tarot reading really free?</summary>
          <p>Yes — completely. No sign-up, no card, no paywall hiding the "real" answer. Pull as many spreads as you like.</p>
        </details>
        <details>
          <summary>Can tarot predict my future?</summary>
          <p>No, and we'd be wary of anyone who says it can. Tarot is a tool for reflection — it shows you the patterns and feelings you're carrying so you can make your own clearer choice. The future stays yours.</p>
        </details>
        <details>
          <summary>How often should I pull cards?</summary>
          <p>Whenever a real question is sitting with you. Many people return every few weeks rather than every day — a reading lands harder when you've actually lived a little between draws.</p>
        </details>
        <details>
          <summary>Which deck do you use?</summary>
          <p>Our interpretations follow the traditional Rider–Waite–Smith meanings — the same symbolic language most tarot readers learn from — across all 78 cards.</p>
        </details>
        <details>
          <summary>What's the difference between past, present and future cards?</summary>
          <p>The first card speaks to what shaped the situation, the second to where you stand now, and the third to where it's heading if things continue on their current arc. Read together, they trace the shape of your question.</p>
        </details>
      </div>

      <p class="about-foot">For reflection and entertainment. 18+. Tarot is not a substitute for medical, legal, or financial advice — trust your own judgement for the decisions that matter.</p>
    </section>

    <section class="browse-all" aria-label="Browse all tarot cards">
      <p class="browse-kicker"><span class="star">✦</span> THE FULL DECK</p>
      <h2 class="browse-title">All 78 Cards</h2>

      <div class="browse-group">
        <p class="browse-group-label">MAJOR ARCANA</p>
        <ul class="browse-grid">
          {TAROT_CARDS.filter(c => c.arcana === 'major').map((c) => (
            <li>
              <a class="browse-card" href={`/tarot/cards/${c.slug}/`}>
                <span class="bc-roman">{c.roman || '—'}</span>
                <span class="bc-name">{c.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {['wands', 'cups', 'swords', 'pentacles'].map((suit) => (
        <div class="browse-group">
          <p class="browse-group-label">{SUIT_LABELS[suit]?.toUpperCase() ?? suit.toUpperCase()}</p>
          <ul class="browse-grid">
            {TAROT_CARDS.filter(c => c.suit === suit).map((c) => (
              <li>
                <a class="browse-card" href={`/tarot/cards/${c.slug}/`}>
                  <span class="bc-roman">{c.roman || c.number}</span>
                  <span class="bc-name">{c.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

  </main>
</BaseLayout>

<style>
  /* ===== A-version: immersive deep-night stage ===== */
  /* paint the whole page dark on the tarot route (overrides global cream body) */
  :global(body:has(.tarot)) { background: #0c0a22 !important; }
  .night {
    position: fixed; inset: 0; z-index: -1; pointer-events: none;
    background:
      radial-gradient(120% 80% at 50% -10%, #2a2358 0%, transparent 60%),
      radial-gradient(90% 70% at 50% 110%, rgba(217,164,65,0.10), transparent 60%),
      linear-gradient(180deg, #1a1640 0%, #141031 45%, #0c0a22 100%);
  }
  .night-stars { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .night-aura {
    position: absolute; inset: 0;
    background: radial-gradient(60% 45% at 50% 32%, rgba(128,104,190,0.22), transparent 70%);
    mix-blend-mode: screen;
  }

  .tarot { padding-bottom: 6rem; min-height: 70vh; position: relative; z-index: 1; }
  /* lift text into light on the dark stage */
  .tarot h1 { color: #f4efe2; }
  .tarot .lede { color: rgba(244,239,226,0.74); }
  .tarot .datestamp { color: rgba(244,239,226,0.66); }
  .tarot .datestamp .star { color: var(--gold); }
  .stage { display: none; }
  .stage.is-active { display: block; animation: rise 0.5s ease both; }
  @keyframes rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

  .datestamp { text-align: center; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 1.6rem; }
  .datestamp .star { color: var(--gold); margin-right: 0.4rem; }
  .hero { text-align: center; margin-bottom: 2.4rem; }
  h1 { font-size: clamp(2.4rem, 6vw, 4.5rem); font-weight: 500; line-height: 1.04; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 1rem; }
  .lede { font-size: clamp(1rem, 1.3vw, 1.15rem); color: var(--ink-soft); font-style: italic; max-width: 540px; margin: 0 auto; }

  /* bottom editorial / SEO copy — dark stage */
  .tarot-about {
    max-width: 880px; margin: 4.5rem auto 0; padding: clamp(2rem, 5vw, 3.4rem) clamp(1.4rem, 4vw, 3rem);
    border-top: 1px solid rgba(244,239,226,0.14);
    position: relative; z-index: 1;
  }
  .about-kicker { text-align: center; font-size: 0.7rem; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: 0.7rem; }
  .about-kicker .star { margin-right: 0.4rem; }
  .tarot-about h2 { text-align: center; font-size: clamp(1.7rem, 3.6vw, 2.5rem); font-weight: 500; line-height: 1.1; letter-spacing: -0.02em; color: #f4efe2; margin-bottom: 2rem; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem 2.4rem; }
  @media (max-width: 680px) { .about-grid { grid-template-columns: 1fr; gap: 1.2rem; } }
  .about-grid p { font-size: 0.98rem; line-height: 1.72; color: rgba(244,239,226,0.74); margin: 0; }
  .about-grid em { color: var(--gold); font-style: italic; }

  /* how it works */
  .about-how { margin-top: 3.4rem; }
  .about-how h3, .about-faq h3 {
    text-align: center; font-size: clamp(1.2rem, 2.4vw, 1.5rem); font-weight: 500;
    letter-spacing: -0.01em; color: #f4efe2; margin-bottom: 1.6rem;
  }
  .how-steps { list-style: none; max-width: 640px; margin: 0 auto; padding: 0; display: grid; gap: 0.9rem; }
  .how-steps li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.96rem; line-height: 1.66; color: rgba(244,239,226,0.76); }
  .how-steps strong { color: #f4efe2; font-weight: 600; }
  .how-n {
    flex: none; width: 30px; height: 30px; border-radius: 50%;
    border: 1px solid rgba(217,164,65,0.55); color: var(--gold);
    font-size: 0.86rem; font-weight: 600; line-height: 28px; text-align: center;
  }

  /* faq */
  .about-faq { margin-top: 3.4rem; max-width: 680px; margin-left: auto; margin-right: auto; }
  .about-faq details {
    border-bottom: 1px solid rgba(244,239,226,0.12); padding: 1rem 0;
  }
  .about-faq summary {
    cursor: pointer; list-style: none; font-size: 1rem; font-weight: 500; color: #f4efe2;
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
  }
  .about-faq summary::-webkit-details-marker { display: none; }
  .about-faq summary::after { content: '+'; color: var(--gold); font-size: 1.3rem; line-height: 1; transition: transform 0.2s; }
  .about-faq details[open] summary::after { transform: rotate(45deg); }
  .about-faq details p { margin-top: 0.7rem; font-size: 0.93rem; line-height: 1.7; color: rgba(244,239,226,0.7); }

  .about-foot { text-align: center; font-size: 0.78rem; letter-spacing: 0.04em; color: rgba(244,239,226,0.5); margin-top: 2.6rem; }

  /* browse all cards */
  .browse-all {
    max-width: 960px; margin: 4.5rem auto 0; padding: clamp(2rem, 5vw, 3rem) clamp(1.4rem, 4vw, 3rem);
    border-top: 1px solid rgba(244,239,226,0.14);
    position: relative; z-index: 1;
  }
  .browse-kicker { text-align: center; font-size: 0.7rem; letter-spacing: 0.26em; text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: 0.7rem; }
  .browse-kicker .star { margin-right: 0.4rem; }
  .browse-title { text-align: center; font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 500; letter-spacing: -0.02em; color: #f4efe2; margin-bottom: 2.5rem; }
  .browse-group { margin-bottom: 2rem; }
  .browse-group-label {
    font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 0.8rem; text-align: center;
  }
  .browse-grid {
    list-style: none; display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 0.55rem;
  }
  .browse-card {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.7rem 0.4rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(244,239,226,0.14);
    border-radius: 14px;
    text-align: center;
    transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  }
  .browse-card:hover { transform: translateY(-2px); border-color: rgba(217,164,65,0.5); box-shadow: 0 8px 20px rgba(0,0,0,0.2); }
  .bc-roman { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.14em; color: var(--gold); }
  .bc-name { font-size: 0.76rem; font-weight: 500; color: #f4efe2; }

  /* STATE 1 — ask */
  .ask-form { max-width: 560px; margin: 0 auto; }
  .ask-wrap { position: relative; margin-bottom: 1.4rem; }
  .ask-input {
    width: 100%; box-sizing: border-box;
    padding: 1.15rem 4rem 1.15rem 1.5rem;
    border-radius: 999px;
    border: 1px solid rgba(244,239,226,0.22);
    background: rgba(255,255,255,0.06);
    font-family: inherit; font-size: 1rem; color: #f4efe2;
    backdrop-filter: blur(4px);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .ask-input:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 0 3px rgba(217,164,65,0.18); }
  .ask-input::placeholder { color: rgba(244,239,226,0.5); }
  .ask-send {
    position: absolute; right: 6px; top: 50%; transform: translateY(-50%);
    width: 46px; height: 46px; border-radius: 50%; border: none; cursor: pointer;
    background: var(--gold); color: #161430;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.18s, opacity 0.18s;
  }
  .ask-send:hover { transform: translateY(-50%) scale(1.06); }
  .chips { display: flex; gap: 0.6rem; justify-content: center; }
  .chip {
    font-family: inherit; font-size: 0.8rem; letter-spacing: 0.04em;
    padding: 0.5rem 1.15rem; border-radius: 999px; cursor: pointer;
    border: 1px solid rgba(244,239,226,0.22); background: rgba(255,255,255,0.05); color: rgba(244,239,226,0.72);
    transition: all 0.18s;
  }
  .chip:hover { color: #f4efe2; border-color: rgba(244,239,226,0.4); }
  .chip.is-on { background: var(--gold); color: #161430; border-color: var(--gold); }

  /* STATE 2 — shuffle fan */
  .fan { position: relative; height: 380px; max-width: 720px; margin: 1rem auto 0; }
  .fan-card {
    position: absolute; left: 50%; bottom: 24px;
    width: 168px; margin-left: -84px; aspect-ratio: 100/160;
    transform-origin: 50% 120%;
    transform: rotate(var(--r));
    filter: drop-shadow(0 12px 26px rgba(80,60,120,0.22));
    animation: wobble 2.6s ease-in-out infinite;
  }
  .fan-card svg { width: 100%; height: 100%; display: block; }
  @keyframes wobble {
    0%, 100% { transform: rotate(var(--r)) translateY(0); }
    50%      { transform: rotate(calc(var(--r) + 1.5deg)) translateY(-7px); }
  }

  /* STATE 3 — pick (page is already dark; keep stage transparent) */
  .stage-pick.is-active {
    position: relative;
    padding: 1rem 0 2rem;
    overflow: visible;
  }
  /* drifting starfield — two parallax layers that slowly pan */
  .pick-sky, .pick-sky::after {
    content: ''; position: absolute; inset: -10% 0; z-index: 0; pointer-events: none;
  }
  .pick-sky {
    background-image:
      radial-gradient(1.4px 1.4px at 12% 22%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 28% 64%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1.6px 1.6px at 44% 14%, rgba(217,164,65,0.9), transparent),
      radial-gradient(1px 1px at 58% 48%, rgba(255,255,255,0.65), transparent),
      radial-gradient(1.3px 1.3px at 70% 26%, rgba(255,255,255,0.85), transparent),
      radial-gradient(1px 1px at 82% 58%, rgba(217,164,65,0.75), transparent),
      radial-gradient(1.5px 1.5px at 90% 18%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1px 1px at 20% 40%, rgba(255,255,255,0.55), transparent),
      radial-gradient(1.2px 1.2px at 36% 80%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 64% 76%, rgba(217,164,65,0.6), transparent),
      radial-gradient(1.4px 1.4px at 76% 70%, rgba(255,255,255,0.7), transparent);
    animation: skyTwinkle 5.5s ease-in-out infinite, skyDriftA 90s linear infinite;
  }
  /* second, denser parallax layer drifting the opposite way */
  .pick-sky::after {
    background-image:
      radial-gradient(1px 1px at 8% 50%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1.2px 1.2px at 24% 30%, rgba(217,164,65,0.55), transparent),
      radial-gradient(1px 1px at 40% 66%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1.3px 1.3px at 54% 20%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 68% 54%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1.2px 1.2px at 86% 38%, rgba(217,164,65,0.5), transparent),
      radial-gradient(1px 1px at 94% 70%, rgba(255,255,255,0.5), transparent);
    opacity: 0.7;
    animation: skyDriftB 130s linear infinite;
  }
  @keyframes skyTwinkle { 0%,100% { opacity: 0.55; } 50% { opacity: 1; } }
  @keyframes skyDriftA { from { transform: translateX(0); } to { transform: translateX(-40px); } }
  @keyframes skyDriftB { from { transform: translateX(0); } to { transform: translateX(36px); } }
  /* floating gold dust — soft motes rising through the stage */
  .pick-dust { position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
  .pick-dust i {
    position: absolute; bottom: -8px; width: 3px; height: 3px; border-radius: 50%;
    background: radial-gradient(circle, rgba(217,164,65,0.95), rgba(217,164,65,0) 70%);
    opacity: 0; animation: dustRise linear infinite;
  }
  @keyframes dustRise {
    0% { transform: translateY(0) translateX(0) scale(0.6); opacity: 0; }
    12% { opacity: 0.9; }
    80% { opacity: 0.7; }
    100% { transform: translateY(-440px) translateX(var(--dx,14px)) scale(1.1); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pick-sky, .pick-sky::after, .pick-dust i { animation: none !important; }
  }
  .stage-pick .hero, .stage-pick .datestamp, .stage-pick .pick-counter, .stage-pick .pick-fan { position: relative; z-index: 2; }
  .stage-pick .hero h1, .stage-pick .lede, .stage-pick .datestamp { color: #f1ecdf; }
  .stage-pick .lede { color: rgba(241,236,223,0.72); }
  .stage-pick .datestamp { color: rgba(241,236,223,0.66); }
  .pick-counter {
    text-align: center; font-size: 0.74rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 1.8rem;
  }
  .pick-counter.done { color: #f1ecdf; }
  .pick-fan {
    position: relative; height: 470px; max-width: 920px; margin: 0 auto;
    touch-action: manipulation;
  }
  .pick-card {
    position: absolute; left: 50%; bottom: 0;
    width: 194px; margin-left: -97px; aspect-ratio: 100/160;
    padding: 0; border: none; background: transparent; cursor: pointer;
    transform-origin: 50% 1180px;
    transform: rotate(calc((var(--i) - (var(--n) - 1) / 2) * 3deg));
    transition: transform 0.34s cubic-bezier(0.34,1.4,0.5,1), filter 0.3s;
    filter: drop-shadow(-7px 4px 9px rgba(0,0,0,0.55));
  }
  .pick-card svg { width: 100%; height: 100%; display: block; pointer-events: none; }
  .pick-card:hover, .pick-card:focus-visible {
    transform: rotate(calc((var(--i) - (var(--n) - 1) / 2) * 3deg)) translateY(-34px);
    outline: none;
    filter: drop-shadow(0 20px 34px rgba(217,164,65,0.5));
    z-index: 5;
  }
  .pick-card.is-picked {
    transform: rotate(calc((var(--i) - (var(--n) - 1) / 2) * 3deg)) translateY(-60px);
    filter: drop-shadow(0 0 0 2px rgba(217,164,65,0.95)) drop-shadow(0 20px 34px rgba(217,164,65,0.55));
    z-index: 6;
  }
  .pick-card.is-spent { pointer-events: none; opacity: 0.4; }
  .pick-badge {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%) scale(0);
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--gold); color: #161430;
    font-size: 0.78rem; font-weight: 700; line-height: 26px; text-align: center;
    box-shadow: 0 0 12px rgba(217,164,65,0.7);
    transition: transform 0.28s cubic-bezier(0.34,1.5,0.5,1);
  }
  .pick-card.is-picked .pick-badge { transform: translateX(-50%) scale(1); }
  @media (max-width: 640px) {
    .pick-fan { height: 320px; max-width: 100%; }
    .pick-card { width: 112px; margin-left: -56px; transform-origin: 50% 720px;
      transform: rotate(calc((var(--i) - (var(--n) - 1) / 2) * 2.5deg)); }
    .pick-card:hover, .pick-card:focus-visible {
      transform: rotate(calc((var(--i) - (var(--n) - 1) / 2) * 2.5deg)) translateY(-26px); }
    .pick-card.is-picked {
      transform: rotate(calc((var(--i) - (var(--n) - 1) / 2) * 2.5deg)) translateY(-48px); }
  }

  /* STATE 4 — reveal */
  .reveal-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.8rem; max-width: 880px; margin: 0 auto 1rem; align-items: start; }
  @media (max-width: 740px) { .reveal-row { grid-template-columns: 1fr; gap: 2.4rem; max-width: 280px; } }
  .slot { text-align: center; }
  .rcard {
    appearance: none; border: none; background: transparent; padding: 0; cursor: pointer;
    width: clamp(200px, 24vw, 250px); aspect-ratio: 100/160; margin: 0 auto 1.2rem;
    display: block; perspective: 900px;
    filter: drop-shadow(0 14px 30px rgba(22,24,58,0.2));
  }
  .rflip { position: relative; display: block; width: 100%; height: 100%; transform-style: preserve-3d; transition: transform 0.7s cubic-bezier(0.4,0,0.2,1); }
  .slot.flipped .rflip { transform: rotateY(180deg); }
  .rface { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; border-radius: 11px; overflow: hidden; }
  .rback svg { width: 100%; height: 100%; display: block; }
  .rfront {
    transform: rotateY(180deg);
    background: var(--tint, linear-gradient(165deg, #4a3a72, #2d2350));
    border: 1px solid rgba(255,255,255,0.45);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 1rem; color: #f6f1e8;
  }
  .rf-roman { font-size: 0.72rem; letter-spacing: 0.24em; color: rgba(246,241,232,0.9); margin-bottom: 0.5rem; }
  .rf-glyph { font-size: 1.6rem; color: var(--gold); margin-bottom: 0.5rem; }
  .rf-name { font-size: clamp(1rem, 1.4vw, 1.2rem); font-weight: 500; line-height: 1.15; letter-spacing: -0.01em; color: #f6f1e8; }
  .rf-keys { font-size: 0.52rem; letter-spacing: 0.14em; line-height: 1.5; color: rgba(246,241,232,0.86); margin-top: 0.5rem; }

  .r-pos { font-size: 0.68rem; letter-spacing: 0.24em; text-transform: uppercase; color: rgba(244,239,226,0.6); font-weight: 600; margin-bottom: 0.5rem; }
  .r-meaning { font-size: 0.92rem; line-height: 1.62; color: rgba(244,239,226,0.86); max-width: 240px; margin: 0 auto; opacity: 0; transition: opacity 0.45s; }
  .slot.flipped .r-meaning { opacity: 1; }

  .tap-all-hint { text-align: center; font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(244,239,226,0.55); margin: 2rem 0 2.4rem; transition: opacity 0.3s; }

  .spread-reading {
    max-width: 860px; margin: 2rem auto 2.4rem; padding: clamp(1.4rem, 3vw, 2.2rem);
    border: 1px solid rgba(244,239,226,0.16); border-radius: 28px;
    background: rgba(255,255,255,0.05); backdrop-filter: blur(8px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    animation: rise 0.45s ease both;
  }
  .reading-kicker { text-align: center; font-size: 0.68rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: 0.65rem; }
  .reading-title { text-align: center; font-size: clamp(1.45rem, 3vw, 2rem); font-weight: 500; letter-spacing: -0.02em; margin-bottom: 1rem; color: #f4efe2; }
  .reading-summary, .reading-advice { color: rgba(244,239,226,0.82); font-size: 1rem; line-height: 1.75; max-width: 680px; margin: 0 auto; text-align: center; }
  .reading-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1.6rem 0; }
  .reading-grid article { border-radius: 20px; padding: 1.1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(244,239,226,0.12); }
  .reading-grid span { display: block; font-size: 0.66rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: 0.55rem; }
  .reading-grid p { font-size: 0.92rem; line-height: 1.65; color: rgba(244,239,226,0.78); }
  @media (max-width: 740px) { .reading-grid { grid-template-columns: 1fr; } }

  .reveal-actions { display: flex; gap: 0.8rem; justify-content: center; }
  .btn-ghost, .btn-again {
    font-family: inherit; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.16em;
    padding: 0.9rem 2rem; border-radius: 999px; cursor: pointer; transition: all 0.2s;
    text-transform: uppercase;
  }
  .btn-ghost { background: transparent; border: 1px solid rgba(244,239,226,0.5); color: #f4efe2; }
  .btn-ghost:hover { background: rgba(244,239,226,0.12); }
  .btn-again { background: var(--gold); border: 1px solid var(--gold); color: #161430; }
  .btn-again:hover { opacity: 0.88; }
  .hero,
  .intro,
  .section,
  .spread,
  .cards,
  .library,
  .feature-grid,
  .tarot-grid {
    color: #f4efe2;
  }

  .hero p,
  .intro p,
  .section p,
  .spread p,
  .card p,
  .tarot-card p,
  .feature p,
  .meta,
  .description,
  .card-keywords,
  .feature-meta {
    color: rgba(244, 239, 226, 0.78);
  }

  .card,
  .tarot-card,
  .feature,
  .spread-card {
    color: #f4efe2;
  }
</style>

<script>
  const root = document.querySelector('.tarot');
  const deck = JSON.parse(root?.getAttribute('data-cards') || '[]');
  const stages = {
    ask: document.querySelector('[data-stage="ask"]'),
    shuffle: document.querySelector('[data-stage="shuffle"]'),
    pick: document.querySelector('[data-stage="pick"]'),
    reveal: document.querySelector('[data-stage="reveal"]'),
  };
  const input = document.querySelector('.ask-input');
  const form = document.querySelector('.ask-form');
  const chips = Array.from(document.querySelectorAll('.chip'));
  const revealQ = document.querySelector('.reveal-q');
  const slots = Array.from(document.querySelectorAll('.slot'));
  const tapHint = document.querySelector('.tap-all-hint');
  const againBtn = document.querySelector('.btn-again');
  const readSpreadBtn = document.querySelector('.btn-read-spread');
  const readingBox = document.querySelector('.spread-reading');
  const readingSummary = document.querySelector('.reading-summary');
  const readingPast = document.querySelector('.reading-past');
  const readingPresent = document.querySelector('.reading-present');
  const readingFuture = document.querySelector('.reading-future');
  const readingAdvice = document.querySelector('.reading-advice');

  const pickCards = Array.from(document.querySelectorAll('.pick-card'));
  const pickLeft = document.querySelector('.pick-left');
  const pickCounter = document.querySelector('.pick-counter');

  const NEED = 3;
  let drawn = [];
  let pool = [];
  let revealed = 0;

  function show(name) {
    Object.entries(stages).forEach(([k, el]) => {
      if (!el) return;
      const on = k === name;
      el.hidden = !on;
      el.classList.toggle('is-active', on);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // crypto-backed random index
  function rand(n) {
    const a = new Uint32Array(1);
    crypto.getRandomValues(a);
    return a[0] % n;
  }
  function drawOne() {
    if (!pool.length) return deck[rand(deck.length)];
    const j = rand(pool.length);
    return deck[pool.splice(j, 1)[0]];
  }

  function makeSpreadReading(question, cards) {
    const [past, present, future] = cards;
    const subject = question ? 'your question' : 'this moment';
    return {
      summary: `${past.name}, ${present.name}, and ${future.name} form a three-step story around ${subject}: what has shaped the situation, what is asking for your attention now, and the direction the energy wants to move next. The spread is not a fixed prediction; it is a mirror for choosing with more clarity.`,
      past: `${past.name} points to the root of the matter: ${past.up} This is the pattern, lesson, or residue you are bringing into the reading.`,
      present: `${present.name} describes the live center of the spread: ${present.up} This is where your attention is most useful right now.`,
      future: `${future.name} shows the likely path if you keep listening to the current thread: ${future.up} Treat it as guidance for the next step, not a sentence carved in stone.`,
      advice: `Read the three cards together as a movement from ${past.keys.toLowerCase()} toward ${future.keys.toLowerCase()}, with ${present.name} as the bridge. The practical advice is simple: acknowledge what brought you here, act on the present card first, and let the future card be a direction rather than something to force.`
    };
  }

  function showSpreadReading() {
    if (!drawn.length) return;
    const q = (input?.value || '').trim();
    const reading = makeSpreadReading(q, drawn);
    if (readingSummary) readingSummary.textContent = reading.summary;
    if (readingPast) readingPast.textContent = reading.past;
    if (readingPresent) readingPresent.textContent = reading.present;
    if (readingFuture) readingFuture.textContent = reading.future;
    if (readingAdvice) readingAdvice.textContent = reading.advice;
    if (readingBox) readingBox.hidden = false;
  }

  chips.forEach((c) => c.addEventListener('click', () => {
    chips.forEach((x) => x.classList.remove('is-on'));
    c.classList.add('is-on');
    if (input && !input.value.trim()) input.placeholder = c.dataset.chip + ' — type your question…';
  }));

  // populate the three reveal slots from the chosen cards, then go to reveal
  function toReveal() {
    revealed = 0;
    slots.forEach((slot, i) => {
      slot.classList.remove('flipped');
      const card = drawn[i];
      slot.querySelector('.rf-roman').textContent = card.roman;
      slot.querySelector('.rf-name').textContent = card.name;
      slot.querySelector('.rf-keys').textContent = card.keys;
      slot.querySelector('.r-meaning').textContent = card.up;
    });
    if (tapHint) tapHint.style.opacity = '1';
    if (readingBox) readingBox.hidden = true;
    show('reveal');
  }

  function resetPickFan() {
    pickCards.forEach((c) => {
      c.classList.remove('is-picked', 'is-spent');
      const b = c.querySelector('.pick-badge');
      if (b) b.textContent = '';
    });
    if (pickLeft) pickLeft.textContent = String(NEED);
    if (pickCounter) {
      pickCounter.classList.remove('done');
      pickCounter.innerHTML = '<span class="pick-left">' + NEED + '</span> cards left';
    }
  }

  pickCards.forEach((card) => {
    card.addEventListener('click', () => {
      if (card.classList.contains('is-picked') || drawn.length >= NEED) return;
      const chosen = drawOne();
      drawn.push(chosen);
      card.classList.add('is-picked');
      const badge = card.querySelector('.pick-badge');
      if (badge) badge.textContent = String(drawn.length);
      // lock siblings briefly so the badge animates, then mark spent
      setTimeout(() => card.classList.add('is-spent'), 280);

      const left = NEED - drawn.length;
      const counter = document.querySelector('.pick-counter');
      if (counter) {
        if (left > 0) {
          counter.innerHTML = '<span class="pick-left">' + left + '</span> card' + (left === 1 ? '' : 's') + ' left';
        } else {
          counter.classList.add('done');
          counter.textContent = 'The cards are yours.';
        }
      }

      if (drawn.length >= NEED) {
        setTimeout(toReveal, 760);
      }
    });
  });

  function begin(e) {
    e?.preventDefault();
    const q = (input?.value || '').trim();
    if (revealQ) {
      revealQ.textContent = q
        ? '\u201C' + q + '\u201D'
        : 'Past, present, future — a small constellation around your question.';
    }
    // fresh deck + selection
    drawn = [];
    pool = deck.map((_, i) => i);
    resetPickFan();
    show('shuffle');
    setTimeout(() => show('pick'), 1600);
  }

  form?.addEventListener('submit', begin);

  slots.forEach((slot) => {
    slot.querySelector('.rcard')?.addEventListener('click', () => {
      if (slot.classList.contains('flipped')) return;
      slot.classList.add('flipped');
      revealed += 1;
      if (revealed >= slots.length && tapHint) tapHint.style.opacity = '0';
    });
  });

  readSpreadBtn?.addEventListener('click', () => {
    slots.forEach((slot) => slot.classList.add('flipped'));
    revealed = slots.length;
    if (tapHint) tapHint.style.opacity = '0';
    showSpreadReading();
    readingBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  againBtn?.addEventListener('click', () => {
    revealed = 0;
    slots.forEach((s) => s.classList.remove('flipped'));
    if (readingBox) readingBox.hidden = true;
    if (input) input.value = '';
    drawn = [];
    show('ask');
  });

  /* ===== deep-night starfield canvas (learns from tarotoo) ===== */
  (function starfield() {
    const canvas = document.querySelector('.night-stars');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
    let stars = [];

    function build() {
      w = canvas.clientWidth; h = canvas.clientHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.round((w * h) / 7000);
      stars = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: Math.random() * 1.3 + 0.3,
        base: Math.random() * 0.5 + 0.25,
        tw: Math.random() * Math.PI * 2,
        tws: Math.random() * 0.018 + 0.004,
        gold: Math.random() < 0.18,
        vx: (Math.random() - 0.5) * 0.04,
        vy: Math.random() * 0.05 + 0.01,
      }));
    }

    function frame() {
      ctx.clearRect(0, 0, w, h);
      for (const s of stars) {
        s.tw += s.tws;
        const a = s.base + Math.sin(s.tw) * 0.35;
        s.x += s.vx; s.y += s.vy;
        if (s.y > h + 2) { s.y = -2; s.x = Math.random() * w; }
        if (s.x < -2) s.x = w + 2; else if (s.x > w + 2) s.x = -2;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = s.gold
          ? 'rgba(217,164,65,' + Math.max(0, a) + ')'
          : 'rgba(255,255,255,' + Math.max(0, a) + ')';
        ctx.fill();
      }
      if (!reduce) requestAnimationFrame(frame);
    }

    build();
    if (reduce) { frame(); }
    else { requestAnimationFrame(frame); }
    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(build, 200);
    });
  })();
</script>
