---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import { SIGNS, SIGN_BY_SLUG } from '../../../data/signs';
import data from '../../../data/horoscopes.json';

export function getStaticPaths() {
  return SIGNS.map((s) => ({ params: { sign: s.slug } }));
}

const { sign } = Astro.params;
const meta = SIGN_BY_SLUG[sign];
const reading = data.daily[sign];

const generatedDate = data.meta?.daily_generated || data.meta?.generated;
const today = generatedDate
  ? new Date(generatedDate + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })
  : new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
const stars = (n) => '★★★★★☆☆☆☆☆'.slice(5 - n, 10 - n);
const eyebrow = `${meta.element} · ${meta.modality} · ${meta.ruler.replace(/^the /, '').toUpperCase()}`;
const pairA = SIGN_BY_SLUG[meta.pairs[0]];
const pairB = SIGN_BY_SLUG[meta.pairs[1]];
---
<BaseLayout title={`${meta.name} Daily Horoscope · cusprose`} path={`/horoscopes/${sign}/`} description={`Today's horoscope for ${meta.name} — written, not generated. Updated daily.`}>
  <Nav current="Horoscopes" />

  <main class="sign-page">
    <div class="container">
      <p class="crumb">HOROSCOPES / {meta.name.toUpperCase()}</p>

      <header class="head">
        <span class="glyph" aria-hidden="true">{meta.glyph}</span>
        <div>
          <p class="eyebrow"><span class="star">✦</span> {eyebrow}</p>
          <h1>{meta.name}.</h1>
          <p class="dates">{meta.dates}</p>
        </div>
      </header>

      <div class="grid">
        <article class="reading">
          <p class="date-label">TODAY · {today}</p>
          <blockquote>{reading.quote}</blockquote>
          {reading.body.map((p) => <p class="body">{p}</p>)}

          <div class="ratings">
            <div><p class="r-label">LOVE</p><p class="r-stars">{stars(reading.ratings.love)}</p></div>
            <div><p class="r-label">WORK</p><p class="r-stars">{stars(reading.ratings.work)}</p></div>
            <div><p class="r-label">MONEY</p><p class="r-stars">{stars(reading.ratings.money)}</p></div>
            <div><p class="r-label">MOOD</p><p class="r-stars">{stars(reading.ratings.mood)}</p></div>
          </div>
        </article>

        <aside class="side">
          <div class="panel">
            <p class="p-head">JUMP TO</p>
            <ul>
              <li><a href={`/horoscopes/${sign}/`} aria-current="page">Today</a></li>
              <li><a href={`/horoscopes/${sign}/weekly/`}>This week</a></li>
              <li><a href={`/horoscopes/${sign}/monthly/`}>This month</a></li>
              <li><a href={`/horoscopes/${sign}/yearly/`}>2026 yearly</a></li>
            </ul>
          </div>
          <div class="panel">
            <p class="p-head">PAIRS WELL WITH</p>
            <ul>
              <li><a href="/compatibility/">{pairA.name} &times; {meta.name}</a></li>
              <li><a href="/compatibility/">{pairB.name} &times; {meta.name}</a></li>
              <li><a href="/tarot/">{meta.tarot.name} card</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .sign-page { padding-bottom: 6rem; }
  .crumb { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 2.5rem; }
  .head { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem; }
  .head .glyph { font-size: 4.5rem; color: var(--ink); line-height: 1; }
  .eyebrow { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 0.5rem; }
  .eyebrow .star { color: var(--gold); margin-right: 0.4rem; }
  h1 { font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 500; letter-spacing: -0.025em; line-height: 1; }
  .dates { font-size: 0.85rem; color: var(--ink-soft); margin-top: 0.3rem; }

  .grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2.5rem; align-items: start; }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }

  .reading {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 22px;
    padding: 2rem 2.2rem;
  }
  .date-label { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
  blockquote { font-size: 1.35rem; font-style: italic; line-height: 1.35; color: var(--ink); margin-bottom: 1.5rem; }
  .body { font-size: 1rem; line-height: 1.65; color: var(--ink); margin-bottom: 1.1rem; }

  .ratings { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(22,24,58,0.1); }
  .r-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 0.3rem; }
  .r-stars { font-size: 0.95rem; color: var(--gold); letter-spacing: 0.05em; }

  .side { display: flex; flex-direction: column; gap: 1.2rem; }
  .panel { background: var(--surface); border: 1px solid var(--surface-border); border-radius: 18px; padding: 1.3rem 1.5rem; }
  .p-head { font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 0.8rem; }
  .panel ul { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
  .panel a { font-size: 0.92rem; color: var(--ink); border-bottom: 1px solid transparent; transition: border-color 0.18s; }
  .panel a:hover { border-color: var(--ink); }
  .panel a[aria-current="page"] { color: var(--gold); border-color: var(--gold); }
</style>
