const trigrams = [
  { glyph: '☰', name: '乾', roman: 'Qián',  image: 'Heaven', color: '#e8ddf0' },
  { glyph: '☷', name: '坤', roman: 'Kūn',   image: 'Earth',  color: '#f4ddc9' },
  { glyph: '☵', name: '坎', roman: 'Kǎn',   image: 'Water',  color: '#d9e7ce' },
  { glyph: '☲', name: '離', roman: 'Lí',    image: 'Fire',   color: '#e0d5ea' },
  { glyph: '☳', name: '震', roman: 'Zhèn',  image: 'Thunder',color: '#f4ddc9' },
