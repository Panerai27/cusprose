---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

const systems = [
  {
    tag: 'I CHING',
    cn: '易经',
    title: '64 hexagrams,\nread the moment.',
    meta: 'Coin or yarrow · plain-English line readings',
    href: '/iching/',
  },
  {
    tag: 'BAZI',
    cn: '八字',
    title: 'Your four pillars,\nin English.',
    meta: 'Year · Month · Day · Hour — destiny chart',
    href: '/east/bazi/',
  },
  {
    tag: 'FENG SHUI',
    cn: '风水',
    title: 'How space\nshapes the day.',
    meta: 'Bagua, five elements, modern rooms',
    href: '/east/feng-shui/',
  },
  {
    tag: 'ZI WEI DOU SHU',
    cn: '紫微斗数',
    title: 'The emperor\'s chart.',
    meta: '12 palaces · 14 main stars',
    href: '/guides/what-is-zi-wei/',
  },
];
---
<BaseLayout title="East · I Ching, BaZi, Feng Shui · cusprose" path="/east/" description="Eastern divination — I Ching, BaZi, Feng Shui, Zi Wei Dou Shu — explained in clear English, without the mystic fog.">
  <Nav />

  <main class="east">
    <div class="container">
      <p class="crumb">EAST</p>

      <header class="head">
        <p class="eyebrow"><span class="star">✦</span> 东方占卜 · EASTERN DIVINATION</p>
        <h1>Old systems,<br/>clear English.</h1>
        <p class="lede">
          The I Ching is 3,000 years old. BaZi reads your birth like a chemistry set. Feng Shui is, at heart,
          how a room talks to your nervous system. We translate without flattening.
        </p>
      </header>

      <ul class="grid">
        {systems.map((s) => (
          <li>
            <a class="card" href={s.href}>
              <div class="card-head">
                <span class="tag">{s.tag}</span>
                <span class="cn" aria-hidden="true">{s.cn}</span>
              </div>
              <h2>{s.title}</h2>
              <p class="meta">{s.meta}</p>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>

      <section class="why">
        <p class="why-head">WHY EAST</p>
        <p class="why-body">
          Western astrology asks <em>who you are</em>. The Eastern systems ask <em>what is happening, right now, around you</em>
          — and what to do about it. They're complementary, not competing. Read them side by side.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .east { padding-bottom: 6rem; }
  .crumb { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 2.5rem; }
  .head { max-width: 680px; margin-bottom: 4rem; }
  .eyebrow { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 1.25rem; }
  .eyebrow .star { color: var(--gold); margin-right: 0.4rem; }
  h1 { font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 500; line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 1.4rem; }
  .lede { color: var(--ink-soft); font-size: 1.05rem; line-height: 1.6; }

  .grid { list-style: none; display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; margin-bottom: 4rem; }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }

  .card {
    position: relative;
    display: block;
    padding: 2rem 2.2rem 2.4rem;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 22px;
    transition: transform 0.2s, box-shadow 0.2s;
    min-height: 220px;
  }
  .card:hover { transform: translateY(-3px); box-shadow: 0 18px 40px rgba(22,24,58,0.10); }
  .card-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.2rem; }
  .tag { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-soft); }
  .cn { font-size: 1.4rem; color: var(--gold); letter-spacing: 0.1em; }
  h2 { font-size: 1.6rem; font-weight: 500; line-height: 1.15; letter-spacing: -0.015em; margin-bottom: 1rem; white-space: pre-line; }
  .meta { font-size: 0.85rem; color: var(--ink-soft); }
  .arrow { position: absolute; right: 2.2rem; bottom: 1.8rem; font-size: 1.1rem; color: var(--ink); }

  .why {
    max-width: 720px;
    padding: 2rem 0;
    border-top: 1px solid rgba(22,24,58,0.12);
  }
  .why-head { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
  .why-body { font-size: 1.05rem; line-height: 1.65; color: var(--ink); }
  .why-body em { font-style: italic; color: var(--ink-soft); }
</style>
