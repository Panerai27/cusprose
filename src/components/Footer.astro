---
const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Explore',
    links: [
      { label: 'Tarot', href: '/tarot/' },
      { label: 'Horoscopes', href: '/horoscopes/' },
      { label: 'Compatibility', href: '/compatibility/' },
      { label: 'Birth Chart', href: '/birth-chart/' },
    ],
  },
  {
    heading: 'East',
    links: [
      { label: 'East Hub', href: '/east/' },
      { label: 'BaZi 八字', href: '/east/bazi/' },
      { label: 'Feng Shui', href: '/east/feng-shui/' },
      { label: 'I Ching', href: '/iching/' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About', href: '/about/' },
      { label: 'Guides', href: '/guides/' },
      { label: 'Terms', href: '/terms/' },
      { label: 'Privacy', href: '/privacy/' },
    ],
  },
];
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">cusprose<span class="dot">.</span></a>
      <p class="footer-tagline">Daily divination for the modern soul. East meets West.</p>
    </div>

    <nav class="footer-cols" aria-label="Footer">
      {columns.map((col) => (
        <div class="footer-col">
          <p class="footer-heading">{col.heading}</p>
          <ul>
            {col.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="container footer-bottom">
    <p>© {year} cusprose. All rights reserved.</p>
    <p class="footer-legal">
      <a href="/terms/">Terms</a>
      <span aria-hidden="true">·</span>
      <a href="/privacy/">Privacy</a>
      <span aria-hidden="true">·</span>
      <a href="/about/">About</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding: 3.5rem 0 2.5rem;
    border-top: 1px solid var(--surface-border, rgba(255, 255, 255, 0.7));
    background: var(--surface, rgba(255, 255, 255, 0.45));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    position: relative;
    z-index: 2;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 3rem;
    align-items: start;
  }
  .footer-logo {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .footer-logo .dot { color: var(--gold); }
  .footer-tagline {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-soft, #6e6e8f);
    max-width: 320px;
  }
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .footer-heading {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 1rem;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 0.6rem; }
  .footer-col a {
    font-size: 0.92rem;
    color: var(--ink-soft, #6e6e8f);
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--ink); }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--surface-border, rgba(255, 255, 255, 0.6));
    font-size: 0.8rem;
    color: var(--ink-soft, #6e6e8f);
  }
  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .footer-legal a {
    color: var(--ink-soft, #6e6e8f);
    transition: color 0.2s;
  }
  .footer-legal a:hover { color: var(--ink); }

  @media (max-width: 760px) {
    .footer-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .footer-cols { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 440px) {
    .footer-cols { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
