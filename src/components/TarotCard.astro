---
export interface Props {
  numeral: string;
  name: string;
  keywords: string;
  surface: 'lavender' | 'peach' | 'sage';
  tilt: number;
  glyph: 'star' | 'moon' | 'sun';
  z?: number;
  lift?: string;
}
const { numeral, name, keywords, surface, tilt, glyph, z = 1, lift = '0px' } = Astro.props;
const bg = `var(--card-${surface})`;
---
<div class="tarot" style={`background:${bg};transform:rotate(${tilt}deg) translateY(${lift});z-index:${z};`}>
  <div class="numeral">{numeral}</div>
  <div class="glyph" aria-hidden="true">
    {glyph === 'star' && (
      <svg viewBox="0 0 64 64" width="56" height="56">
        <path d="M32 6 L37 26 L58 27 L41 40 L47 60 L32 48 L17 60 L23 40 L6 27 L27 26 Z"
              fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        <circle cx="32" cy="32" r="2.5" fill="currentColor"/>
      </svg>
    )}
    {glyph === 'moon' && (
      <svg viewBox="0 0 64 64" width="56" height="56">
        <path d="M44 12 A22 22 0 1 0 44 52 A18 18 0 1 1 44 12 Z"
              fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
      </svg>
    )}
    {glyph === 'sun' && (
      <svg viewBox="0 0 64 64" width="56" height="56">
        <circle cx="32" cy="32" r="11" fill="none" stroke="currentColor" stroke-width="1.4"/>
        {[0,45,90,135,180,225,270,315].map((a) => (
          <line
            x1={32 + Math.cos(a*Math.PI/180)*18}
            y1={32 + Math.sin(a*Math.PI/180)*18}
            x2={32 + Math.cos(a*Math.PI/180)*26}
            y2={32 + Math.sin(a*Math.PI/180)*26}
            stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        ))}
      </svg>
    )}
  </div>
  <div class="footer">
    <div class="name">{name}</div>
    <div class="keywords">{keywords}</div>
  </div>
</div>

<style>
  .tarot {
    width: 168px;
    height: 256px;
    border-radius: 14px;
    padding: 1.1rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    box-shadow:
      0 24px 48px -16px rgba(22, 24, 58, 0.22),
      0 4px 12px -4px rgba(22, 24, 58, 0.1),
      inset 0 0 0 1px rgba(255,255,255,0.5);
    color: var(--ink);
    transition: transform 0.5s ease;
  }
  .numeral {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--ink);
    opacity: 0.7;
  }
  .glyph {
    color: var(--gold);
    display: grid;
    place-items: center;
    flex: 1;
  }
  .footer {
    text-align: center;
  }
  .name {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }
  .keywords {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
</style>
