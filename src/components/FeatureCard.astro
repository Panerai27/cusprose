---
export interface Props {
  tag: string;
  title: string[];
  meta: string;
}
const { tag, title, meta } = Astro.props;
---
<article class="feature">
  <div class="tag">{tag}</div>
  <h3 class="title">
    {title.map((line, i) => (
      <span>{line}{i < title.length - 1 && <br/>}</span>
    ))}
  </h3>
  <div class="meta">{meta}</div>
</article>

<style>
  .feature {
    background: var(--surface);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--surface-border);
    border-radius: 20px;
    padding: 2rem 1.75rem;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .title {
    font-size: 1.65rem;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--ink);
    flex: 1;
  }
  .meta {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--ink-soft);
  }
</style>
