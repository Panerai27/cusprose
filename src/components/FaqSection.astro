---
export interface Props {
  items: { q: string; a: string }[];
}
const { items } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---
{items.length > 0 && (
  <section class="faq">
    <p class="faq-head">FREQUENTLY ASKED QUESTIONS</p>
    <dl class="faq-list">
      {items.map((item) => (
        <div class="faq-item">
          <dt>{item.q}</dt>
          <dd>{item.a}</dd>
        </div>
      ))}
    </dl>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </section>
)}

<style>
  .faq { margin-top: 3rem; }
  .faq-head {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }
  .faq-list { margin: 0; }
  .faq-item {
    border-top: 1px solid rgba(22, 24, 58, 0.08);
    padding: 1.2rem 0;
  }
  .faq-item:last-child {
    border-bottom: 1px solid rgba(22, 24, 58, 0.08);
  }
  dt {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  dd {
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.65;
    margin: 0;
  }
</style>
