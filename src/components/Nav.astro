---
export interface Props {
  current?: string;
}
const { current = '' } = Astro.props;
const links = [
  { label: 'Tarot',         href: '/tarot' },
  { label: 'Horoscopes',    href: '/horoscopes' },
  { label: 'Compatibility', href: '/compatibility' },
  { label: 'Birth Chart',   href: '/birth-chart' },
  { label: 'East',          href: '/east' },
  { label: 'Guides',        href: '/guides' },
];
---
<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="logo">cusprose<span class="dot">.</span></a>
    <ul class="links" id="nav-links">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={current === l.label ? 'active' : ''}
            aria-current={current === l.label ? 'page' : undefined}
          >{l.label}</a>
        </li>
      ))}
    </ul>
    <button
      class="burger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <ul class="mobile-links">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={current === l.label ? 'active' : ''}
            aria-current={current === l.label ? 'page' : undefined}
          >{l.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav { padding: 1.75rem 0; position: relative; z-index: 100; }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .logo {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    z-index: 102;
  }
  .logo .dot { color: var(--gold); }
  .links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .links a {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--ink);
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .links a:hover { opacity: 1; }
  .links a.active { opacity: 1; font-weight: 600; }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    z-index: 102;
  }
  .burger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .burger[aria-expanded="true"] .burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger[aria-expanded="true"] .burger-line:nth-child(2) {
    opacity: 0;
  }
  .burger[aria-expanded="true"] .burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 101;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  .mobile-links a {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--ink);
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .mobile-links a:hover,
  .mobile-links a.active { opacity: 1; font-weight: 600; }

  @media (max-width: 900px) {
    .links { display: none; }
    .burger { display: flex; }
  }
</style>

<script>
  const burger = document.querySelector('.burger');
  const menu = document.getElementById('mobile-menu');
  if (burger && menu) {
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!open));
      burger.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
      menu.hidden = open;
      document.body.style.overflow = open ? '' : 'hidden';
    });
    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        burger.setAttribute('aria-expanded', 'false');
        burger.setAttribute('aria-label', 'Open menu');
        menu.hidden = true;
        document.body.style.overflow = '';
      });
    });
  }
</script>
